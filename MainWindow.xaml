<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Width="1850"
        Height="1060"
        MinWidth="1500"
        MinHeight="900"
        WindowStartupLocation="CenterScreen"
        Background="#070B14">

    <Window.Resources>

        <!-- COLORS -->

        <SolidColorBrush x:Key="PrimaryBrush" Color="#4F8CFF"/>
        <SolidColorBrush x:Key="CardBrush" Color="#111827"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#0B1220"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#172554"/>

        <!-- CARD STYLE -->

        <Style x:Key="CardStyle"
               TargetType="Border">

            <Setter Property="Background"
                    Value="{StaticResource CardBrush}"/>

            <Setter Property="CornerRadius"
                    Value="26"/>

            <Setter Property="Padding"
                    Value="22"/>

            <Setter Property="Margin"
                    Value="0,0,18,18"/>

            <Setter Property="BorderBrush"
                    Value="#1E293B"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="RenderTransformOrigin"
                    Value="0.5,0.5"/>

            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1"
                                    ScaleY="1"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>

                <Trigger Property="IsMouseOver"
                         Value="True">

                    <Setter Property="BorderBrush"
                            Value="#2563EB"/>

                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02"
                                            ScaleY="1.02"/>
                        </Setter.Value>
                    </Setter>

                </Trigger>

            </Style.Triggers>

        </Style>

        <!-- SIDEBAR BUTTON -->

        <Style x:Key="SidebarButtonStyle"
               TargetType="Button">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="FontSize"
                    Value="15"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Height"
                    Value="56"/>

            <Setter Property="Margin"
                    Value="0,0,0,12"/>

            <Setter Property="Padding"
                    Value="18,0"/>

            <Setter Property="Background"
                    Value="Transparent"/>

            <Setter Property="BorderBrush"
                    Value="Transparent"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">

                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="10,0"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#172554"/>

                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#2563EB"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <!-- DATAGRID -->

        <Style TargetType="DataGrid">

            <Setter Property="Background"
                    Value="#111827"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="BorderBrush"
                    Value="#1E293B"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="RowBackground"
                    Value="#111827"/>

            <Setter Property="AlternatingRowBackground"
                    Value="#0F172A"/>

            <Setter Property="GridLinesVisibility"
                    Value="None"/>

            <Setter Property="HeadersVisibility"
                    Value="Column"/>

        </Style>

        <!-- DATAGRID ROW -->

        <Style TargetType="DataGridRow">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Background"
                    Value="#111827"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="Height"
                    Value="42"/>

            <Style.Triggers>

                <Trigger Property="IsMouseOver"
                         Value="True">

                    <Setter Property="Background"
                            Value="#172554"/>

                </Trigger>

                <Trigger Property="IsSelected"
                         Value="True">

                    <Setter Property="Background"
                            Value="#2563EB"/>

                </Trigger>

            </Style.Triggers>

        </Style>

        <!-- DATAGRID COLUMN HEADER -->

        <Style TargetType="DataGridColumnHeader">

            <Setter Property="Background"
                    Value="#0F172A"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="FontWeight"
                    Value="Bold"/>

            <Setter Property="BorderBrush"
                    Value="#1E293B"/>

            <Setter Property="BorderThickness"
                    Value="0,0,0,1"/>

            <Setter Property="Padding"
                    Value="14,10"/>

        </Style>

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->

        <Border Background="{StaticResource SidebarBrush}"
                BorderBrush="#111827"
                BorderThickness="0,0,1,0">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LOGO -->

                <StackPanel Margin="30">

                    <Border Width="82"
                            Height="82"
                            CornerRadius="24"
                            Background="{StaticResource PrimaryBrush}">

                        <TextBlock Text="T"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                    </Border>

                    <TextBlock Text="Tidy"
                               FontSize="38"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,18,0,0"/>

                    <TextBlock Text="Modern Windows Intelligence"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="13"
                               Margin="0,6,0,0"/>

                </StackPanel>

                <!-- NAV -->

                <StackPanel Grid.Row="1"
                            Margin="18,10">

                    <Button x:Name="DashboardButton"
                            Click="DashboardButton_Click"
                            Style="{StaticResource SidebarButtonStyle}"
                            Background="#172554"
                            BorderBrush="#2563EB">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="&#xE80F;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="18"
                                       Margin="0,0,14,0"/>

                            <TextBlock Text="Dashboard"/>

                        </StackPanel>

                    </Button>

                    <Button x:Name="AppsButton"
                            Click="AppsButton_Click"
                            Style="{StaticResource SidebarButtonStyle}">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="&#xE719;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="18"
                                       Margin="0,0,14,0"/>

                            <TextBlock Text="Installed Apps"/>

                        </StackPanel>

                    </Button>

                    <Button x:Name="CleanupButton"
                            Click="CleanupButton_Click"
                            Style="{StaticResource SidebarButtonStyle}">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="&#xE74D;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="18"
                                       Margin="0,0,14,0"/>

                                <TextBlock Text="Cleanup"/>

                        </StackPanel>

                    </Button>

                    <Button x:Name="StorageButton"
                            Click="StorageButton_Click"
                            Style="{StaticResource SidebarButtonStyle}">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="&#xE7F8;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="18"
                                       Margin="0,0,14,0"/>

                            <TextBlock Text="Storage"/>

                        </StackPanel>

                    </Button>

                    <Button x:Name="ActivityButton"
                            Click="ActivityButton_Click"
                            Style="{StaticResource SidebarButtonStyle}">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="&#xE9D9;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="18"
                                       Margin="0,0,14,0"/>

                            <TextBlock Text="Activity"/>

                        </StackPanel>

                    </Button>

                </StackPanel>

                <!-- FOOTER -->

                <Border Grid.Row="2"
                        Margin="18"
                        Background="#111827"
                        CornerRadius="18"
                        Padding="18"
                        BorderBrush="#1F2937"
                        BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="SYSTEM STATUS"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"/>

                        <TextBlock Text="Intelligence Engine Active"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Border>

        <!-- CONTENT -->

        <Grid Grid.Column="1"
              Margin="28">

            <!-- DASHBOARD -->

            <ScrollViewer x:Name="DashboardPage"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <TextBlock Text="Dashboard"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,28"/>

                    <UniformGrid Columns="4">

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="CPU"
                                           Foreground="{StaticResource MutedBrush}"/>

                                <TextBlock x:Name="CpuUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,14,0,6"/>

                                <ProgressBar Height="8"
                                             Value="65"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="RAM"
                                           Foreground="{StaticResource MutedBrush}"/>

                                <TextBlock x:Name="RamUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,14,0,0"/>

                                <TextBlock x:Name="RamFigureText"
                                           Foreground="#CBD5E1"
                                           Margin="0,6,0,12"/>

                                <ProgressBar Height="8"
                                             Value="70"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="DISK"
                                           Foreground="{StaticResource MutedBrush}"/>

                                <TextBlock x:Name="DiskUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,14,0,0"/>

                                <TextBlock x:Name="DiskFigureText"
                                           Foreground="#CBD5E1"
                                           Margin="0,6,0,12"/>

                                <ProgressBar Height="8"
                                             Value="80"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="INSTALLED APPS"
                                           Foreground="{StaticResource MutedBrush}"/>

                                <TextBlock x:Name="InstalledCountText"
                                           Text="0"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,14,0,6"/>

                                <TextBlock Text="Applications Detected"
                                           Foreground="#CBD5E1"/>

                            </StackPanel>

                        </Border>

                    </UniformGrid>

                </StackPanel>

            </ScrollViewer>

            <!-- APPS PAGE -->

            <Grid x:Name="AppsPage"
                  Visibility="Collapsed">

                <Border Style="{StaticResource CardStyle}">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,0,0,18">

                            <TextBlock Text="Installed Applications"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBox x:Name="SearchBox"
                                     Width="300"
                                     Height="42"
                                     DockPanel.Dock="Right"
                                     Background="#0F172A"
                                     Foreground="White"
                                     BorderBrush="#1E293B"
                                     Padding="12,0"
                                     TextChanged="SearchBox_TextChanged"/>

                        </DockPanel>

                        <DataGrid x:Name="AppsGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"/>

                    </Grid>

                </Border>

            </Grid>

            <!-- CLEANUP -->

            <Grid x:Name="CleanupPage"
                  Visibility="Collapsed">

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Cleanup Engine"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <Button Content="Scan Leftovers"
                                Width="220"
                                Height="46"
                                Margin="0,24,0,24"
                                Background="#16A34A"
                                Foreground="White"
                                BorderBrush="Transparent"
                                FontWeight="SemiBold"
                                Click="ScanLeftovers_Click"/>

                        <Border Background="#0F172A"
                                CornerRadius="18"
                                Padding="18">

                            <ScrollViewer Height="500">

                                <TextBlock x:Name="LeftoverResultsText"
                                           Foreground="White"
                                           FontSize="15"
                                           TextWrapping="Wrap"/>

                            </ScrollViewer>

                        </Border>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- STORAGE -->

            <Grid x:Name="StoragePage"
                  Visibility="Collapsed">

                <UniformGrid Columns="2">

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="Downloads Folder"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock x:Name="DownloadsSizeText"
                                       FontSize="48"
                                       FontWeight="Bold"
                                       Foreground="#4F8CFF"
                                       Margin="0,24,0,18"/>

                            <ProgressBar Height="10"
                                         Value="60"/>

                        </StackPanel>

                    </Border>

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="Largest Installed Apps"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,18"/>

                            <ScrollViewer Height="500">

                                <TextBlock x:Name="LargestAppsText"
                                           Foreground="#CBD5E1"
                                           FontSize="15"
                                           TextWrapping="Wrap"/>

                            </ScrollViewer>

                        </StackPanel>

                    </Border>

                </UniformGrid>

            </Grid>

            <!-- ACTIVITY -->

            <Grid x:Name="ActivityPage"
                  Visibility="Collapsed">

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Activity Feed"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,20"/>

                        <Border Background="#0F172A"
                                CornerRadius="18"
                                Padding="20">

                            <ScrollViewer Height="620">

                                <TextBlock x:Name="ActivityText"
                                           Foreground="#E2E8F0"
                                           FontSize="15"
                                           LineHeight="28"
                                           TextWrapping="Wrap"/>

                            </ScrollViewer>

                        </Border>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Window>
