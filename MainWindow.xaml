<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Height="780"
        Width="1250"
        WindowStartupLocation="CenterScreen"
        Background="#0F1115">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel>

            <StackPanel>
                <TextBlock Text="Tidy"
                           FontSize="42"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Modern Windows App Removal Utility"
                           Foreground="#AAAAAA"
                           FontSize="14"/>
            </StackPanel>

            <Border DockPanel.Dock="Right"
                    Background="#1E222A"
                    CornerRadius="12"
                    Padding="16,8"
                    HorizontalAlignment="Right">

                <StackPanel>
                    <TextBlock Text="Installed Apps"
                               Foreground="#AAAAAA"
                               FontSize="12"/>

                    <TextBlock x:Name="AppCountText"
                               Text="0"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>

            </Border>

        </DockPanel>

        <!-- Search -->
        <Grid Grid.Row="1"
              Margin="0,24,0,18">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     Height="42"
                     FontSize="15"
                     Padding="12,0"
                     Background="#1A1D24"
                     Foreground="White"
                     BorderBrush="#2C313C"
                     TextChanged="SearchBox_TextChanged"/>

            <Button Grid.Column="1"
                    Margin="16,0,0,0"
                    Content="Refresh"
                    Height="42"
                    Click="Refresh_Click"/>

        </Grid>

        <!-- App List -->
        <Border Grid.Row="2"
                Background="#171A20"
                CornerRadius="14"
                Padding="12">

            <ListView x:Name="AppsList"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="White">

                <ListView.Resources>
                    <Style TargetType="GridViewColumnHeader">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#1F232C"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </ListView.Resources>

                <ListView.View>
                    <GridView>

                        <GridViewColumn Header="Application"
                                        Width="340"
                                        DisplayMemberBinding="{Binding Name}"/>

                        <GridViewColumn Header="Publisher"
                                        Width="220"
                                        DisplayMemberBinding="{Binding Publisher}"/>

                        <GridViewColumn Header="Install Date"
                                        Width="150"
                                        DisplayMemberBinding="{Binding InstallDate}"/>

                        <GridViewColumn Header="Size"
                                        Width="120"
                                        DisplayMemberBinding="{Binding Size}"/>

                    </GridView>
                </ListView.View>

            </ListView>

        </Border>

        <!-- Actions -->
        <WrapPanel Grid.Row="3"
                   Margin="0,20,0,0">

            <Button Content="Uninstall Selected"
                    Width="180"
                    Height="42"
                    Margin="0,0,12,0"
                    Click="Uninstall_Click"/>

            <Button Content="Export CSV"
                    Width="140"
                    Height="42"
                    Margin="0,0,12,0"
                    Click="Export_Click"/>

            <ProgressBar x:Name="MainProgress"
                         Width="240"
                         Height="10"
                         Margin="10,16,0,0"/>

        </WrapPanel>

        <!-- Logs -->
        <Border Grid.Row="4"
                Margin="0,20,0,0"
                Background="#171A20"
                CornerRadius="12"
                Padding="12">

            <TextBox x:Name="Logs"
                     Height="130"
                     Background="Transparent"
                     Foreground="#D0D0D0"
                     BorderThickness="0"
                     FontFamily="Consolas"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>

        </Border>

    </Grid>
</Window>
