<ui:Window x:Class="Tidy.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:ui="http://schemas.modernwpf.com/2019"
           mc:Ignorable="d"
           Title="Tidy"
           Height="920"
           Width="1650"
           MinHeight="850"
           MinWidth="1450"
           Background="#070B14"
           WindowStartupLocation="CenterScreen">

    <ui:Window.Resources>

        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <ui:ThemeResources />
                <ui:XamlControlsResources />

            </ResourceDictionary.MergedDictionaries>

            <!-- COLORS -->

            <SolidColorBrush x:Key="SidebarBrush" Color="#0B1220"/>
            <SolidColorBrush x:Key="CardBrush" Color="#111827"/>
            <SolidColorBrush x:Key="BorderBrushCustom" Color="#1E293B"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>

            <!-- CARD STYLE -->

            <Style x:Key="CardStyle"
                   TargetType="Border">

                <Setter Property="Background"
                        Value="#CC111827"/>

                <Setter Property="CornerRadius"
                        Value="24"/>

                <Setter Property="Padding"
                        Value="20"/>

                <Setter Property="Margin"
                        Value="0,0,20,20"/>

                <Setter Property="BorderBrush"
                        Value="#33FFFFFF"/>

                <Setter Property="BorderThickness"
                        Value="1"/>

            </Style>

            <!-- SIDEBAR BUTTON -->

            <Style x:Key="SidebarButtonStyle"
                   TargetType="Button">

                <Setter Property="Foreground"
                        Value="White"/>

                <Setter Property="FontSize"
                        Value="16"/>

                <Setter Property="FontWeight"
                        Value="SemiBold"/>

                <Setter Property="Height"
                        Value="56"/>

                <Setter Property="Margin"
                        Value="0,0,0,12"/>

                <Setter Property="Background"
                        Value="Transparent"/>

                <Setter Property="BorderBrush"
                        Value="Transparent"/>

                <Setter Property="Cursor"
                        Value="Hand"/>

                <Setter Property="HorizontalContentAlignment"
                        Value="Left"/>

                <Setter Property="Padding"
                        Value="20,0"/>

                <Setter Property="Template">

                    <Setter.Value>

                        <ControlTemplate TargetType="Button">

                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="16">

                                <ContentPresenter VerticalAlignment="Center"/>

                            </Border>

                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver"
                                         Value="True">

                                    <Setter TargetName="border"
                                            Property="Background"
                                            Value="#332563EB"/>

                                </Trigger>

                            </ControlTemplate.Triggers>

                        </ControlTemplate>

                    </Setter.Value>

                </Setter>

            </Style>

        </ResourceDictionary>

    </ui:Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->

        <Border Grid.Column="0"
                Background="{DynamicResource SystemControlAcrylicWindowBrush}">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel Margin="18">

                    <TextBlock Text="Tidy"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="10,20,0,40"/>

                    <Button x:Name="DashboardButton"
                            Content="Dashboard"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="DashboardButton_Click"/>

                    <Button x:Name="AppsButton"
                            Content="Installed Apps"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="AppsButton_Click"/>

                    <Button x:Name="StartupButton"
                            Content="Startup Apps"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="StartupButton_Click"/>

                    <Button x:Name="CleanupButton"
                            Content="Cleanup"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="CleanupButton_Click"/>

                    <Button x:Name="StorageButton"
                            Content="Storage Analyzer"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="StorageButton_Click"/>

                    <Button x:Name="DuplicateButton"
                            Content="Duplicate Finder"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="DuplicateButton_Click"/>

                    <Button x:Name="ThemesButton"
                            Content="Themes"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="ThemesButton_Click"/>

                    <Button x:Name="AiButton"
                            Content="AI Insights"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="AiButton_Click"/>

                    <Button x:Name="ActivityButton"
                            Content="Activity"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="ActivityButton_Click"/>

                </StackPanel>

            </ScrollViewer>

        </Border>

        <!-- MAIN CONTENT -->

        <Grid Grid.Column="1"
              Margin="24">

            <ScrollViewer x:Name="DashboardPage">

                <StackPanel>

                    <TextBlock Text="System Dashboard"
                               FontSize="44"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,24"/>

                    <UniformGrid Columns="4">

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="CPU"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="CpuUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,10,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="RAM"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="RamUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,10,0,0"/>

                                <TextBlock x:Name="RamFigureText"
                                           Foreground="#CBD5E1"
                                           Margin="0,8,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="DISK"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="DiskUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,10,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="GPU"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="GpuUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,10,0,0"/>

                            </StackPanel>

                        </Border>

                    </UniformGrid>

                </StackPanel>

            </ScrollViewer>

        </Grid>

    </Grid>

</ui:Window>
