<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Width="1850"
        Height="1060"
        MinWidth="1500"
        MinHeight="900"
        WindowStartupLocation="CenterScreen"
        Background="#070B14">

    <Window.Resources>

        <SolidColorBrush x:Key="PrimaryBrush" Color="#4F8CFF"/>
        <SolidColorBrush x:Key="CardBrush" Color="#111827"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#0B1220"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#94A3B8"/>

        <!-- CARD STYLE -->

        <Style x:Key="CardStyle"
               TargetType="Border">

            <Setter Property="Background"
                    Value="{StaticResource CardBrush}"/>

            <Setter Property="CornerRadius"
                    Value="26"/>

            <Setter Property="Padding"
                    Value="22"/>

            <Setter Property="Margin"
                    Value="0,0,18,18"/>

            <Setter Property="BorderBrush"
                    Value="#1E293B"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

        </Style>

        <!-- SIDEBAR BUTTON -->

        <Style x:Key="SidebarButtonStyle"
               TargetType="Button">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="FontSize"
                    Value="15"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Height"
                    Value="56"/>

            <Setter Property="Margin"
                    Value="0,0,0,12"/>

            <Setter Property="Padding"
                    Value="18,0"/>

            <Setter Property="Background"
                    Value="Transparent"/>

            <Setter Property="BorderBrush"
                    Value="Transparent"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">

                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="10,0"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#172554"/>

                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#2563EB"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <!-- DATAGRID -->

        <Style TargetType="DataGrid">

            <Setter Property="Background"
                    Value="#111827"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="BorderBrush"
                    Value="#1E293B"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="RowBackground"
                    Value="#111827"/>

            <Setter Property="AlternatingRowBackground"
                    Value="#0F172A"/>

            <Setter Property="GridLinesVisibility"
                    Value="None"/>

        </Style>

        <Style TargetType="DataGridRow">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Background"
                    Value="#111827"/>

            <Setter Property="Height"
                    Value="42"/>

            <Style.Triggers>

                <Trigger Property="IsMouseOver"
                         Value="True">

                    <Setter Property="Background"
                            Value="#172554"/>

                </Trigger>

                <Trigger Property="IsSelected"
                         Value="True">

                    <Setter Property="Background"
                            Value="#2563EB"/>

                </Trigger>

            </Style.Triggers>

        </Style>

        <Style TargetType="DataGridColumnHeader">

            <Setter Property="Background"
                    Value="#0F172A"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="FontWeight"
                    Value="Bold"/>

            <Setter Property="Padding"
                    Value="14,10"/>

        </Style>

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->

        <Border Background="{StaticResource SidebarBrush}">

            <StackPanel Margin="18">

                <TextBlock Text="Tidy"
                           FontSize="38"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="12,18,0,30"/>

                <Button x:Name="DashboardButton"
                        Click="DashboardButton_Click"
                        Style="{StaticResource SidebarButtonStyle}">
                    <TextBlock Text="Dashboard"/>
                </Button>

                <Button x:Name="AppsButton"
                        Click="AppsButton_Click"
                        Style="{StaticResource SidebarButtonStyle}">
                    <TextBlock Text="Installed Apps"/>
                </Button>

                <Button x:Name="CleanupButton"
                        Click="CleanupButton_Click"
                        Style="{StaticResource SidebarButtonStyle}">
                    <TextBlock Text="Cleanup"/>
                </Button>

                <Button x:Name="StorageButton"
                        Click="StorageButton_Click"
                        Style="{StaticResource SidebarButtonStyle}">
                    <TextBlock Text="Storage"/>
                </Button>

                <Button x:Name="ActivityButton"
                        Click="ActivityButton_Click"
                        Style="{StaticResource SidebarButtonStyle}">
                    <TextBlock Text="Activity"/>
                </Button>

            </StackPanel>

        </Border>

        <!-- CONTENT -->

        <Grid Grid.Column="1"
              Margin="28">

            <!-- DASHBOARD -->

            <ScrollViewer x:Name="DashboardPage">

                <StackPanel>

                    <TextBlock Text="Dashboard"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,28"/>

                    <UniformGrid Columns="4">

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="CPU"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="CpuUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,12,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="RAM"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="RamUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,12,0,0"/>

                                <TextBlock x:Name="RamFigureText"
                                           Foreground="#CBD5E1"
                                           Margin="0,8,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="DISK"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="DiskUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,12,0,0"/>

                                <TextBlock x:Name="DiskFigureText"
                                           Foreground="#CBD5E1"
                                           Margin="0,8,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="INSTALLED APPS"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="InstalledCountText"
                                           Text="0"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,12,0,0"/>

                            </StackPanel>

                        </Border>

                    </UniformGrid>

                </StackPanel>

            </ScrollViewer>

            <!-- APPS PAGE -->

            <Grid x:Name="AppsPage"
      Visibility="Collapsed">

    <Border Style="{StaticResource CardStyle}">

        <Grid Margin="0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->

            <DockPanel Grid.Row="0"
                       Margin="0,0,0,20">

                <TextBlock Text="Installed Applications"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right">

                    <!-- SEARCH -->

                    <TextBox x:Name="SearchBox"
                             Width="260"
                             Height="42"
                             Margin="0,0,14,0"
                             Background="#0F172A"
                             Foreground="White"
                             BorderBrush="#1E293B"
                             BorderThickness="1"
                             Padding="12,0"
                             VerticalContentAlignment="Center"
                             FontSize="14"
                             TextChanged="SearchBox_TextChanged"/>

                    <!-- UNINSTALL -->

                    <Button Content="Uninstall Selected"
                            Width="190"
                            Height="42"
                            Background="#DC2626"
                            Foreground="White"
                            BorderBrush="Transparent"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="UninstallSelected_Click">

                        <Button.Style>

                            <Style TargetType="Button">

                                <Setter Property="Template">

                                    <Setter.Value>

                                        <ControlTemplate TargetType="Button">

                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="12">

                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>

                                            </Border>

                                            <ControlTemplate.Triggers>

                                                <Trigger Property="IsMouseOver"
                                                         Value="True">

                                                    <Setter TargetName="border"
                                                            Property="Background"
                                                            Value="#EF4444"/>

                                                </Trigger>

                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>

                                    </Setter.Value>

                                </Setter>

                            </Style>

                        </Button.Style>

                    </Button>

                </StackPanel>

            </DockPanel>

            <!-- DATAGRID -->

            <Border Grid.Row="1"
                    CornerRadius="18"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    Background="#111827"
                    ClipToBounds="True">

                <DataGrid x:Name="AppsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#111827"
                          Foreground="White"
                          BorderThickness="0"
                          RowHeight="42"
                          ColumnHeaderHeight="44"
                          VerticalAlignment="Stretch"
                          HorizontalAlignment="Stretch">

                    <DataGrid.Resources>

                        <!-- COLUMN HEADER -->

                        <Style TargetType="DataGridColumnHeader">

                            <Setter Property="Background"
                                    Value="#0F172A"/>

                            <Setter Property="Foreground"
                                    Value="White"/>

                            <Setter Property="FontWeight"
                                    Value="Bold"/>

                            <Setter Property="FontSize"
                                    Value="14"/>

                            <Setter Property="Padding"
                                    Value="14,10"/>

                            <Setter Property="BorderThickness"
                                    Value="0"/>

                        </Style>

                        <!-- ROWS -->

                        <Style TargetType="DataGridRow">

                            <Setter Property="Background"
                                    Value="#111827"/>

                            <Setter Property="Foreground"
                                    Value="White"/>

                            <Style.Triggers>

                                <Trigger Property="IsMouseOver"
                                         Value="True">

                                    <Setter Property="Background"
                                            Value="#172554"/>

                                </Trigger>

                                <Trigger Property="IsSelected"
                                         Value="True">

                                    <Setter Property="Background"
                                            Value="#2563EB"/>

                                </Trigger>

                            </Style.Triggers>

                        </Style>

                    </DataGrid.Resources>

                </DataGrid>

            </Border>

        </Grid>

    </Border>

</Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>

                            <DockPanel Margin="0,0,0,20">

                                <TextBlock Text="Installed Applications"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="White"/>

                                <StackPanel Orientation="Horizontal"
                                            DockPanel.Dock="Right">

                                    <TextBox x:Name="SearchBox"
                                             Width="260"
                                             Height="42"
                                             Margin="0,0,14,0"
                                             Background="#0F172A"
                                             Foreground="White"
                                             BorderBrush="#1E293B"
                                             Padding="12,0"
                                             TextChanged="SearchBox_TextChanged"/>

                                    <Button Content="Uninstall Selected"
                                            Width="180"
                                            Height="42"
                                            Background="#DC2626"
                                            Foreground="White"
                                            BorderBrush="Transparent"
                                            FontWeight="SemiBold"
                                            Cursor="Hand"
                                            Click="UninstallSelected_Click"/>

                                </StackPanel>

                            </DockPanel>

                            <DataGrid x:Name="AppsGrid"
                                      AutoGenerateColumns="False"/>

                        </StackPanel>

                    </Grid>

                </Border>

            </Grid>

            <!-- CLEANUP -->

            <Grid x:Name="CleanupPage"
                  Visibility="Collapsed">

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Cleanup Engine"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <Button Content="Scan Leftovers"
                                Width="220"
                                Height="46"
                                Margin="0,24,0,24"
                                Background="#16A34A"
                                Foreground="White"
                                BorderBrush="Transparent"
                                FontWeight="SemiBold"
                                Click="ScanLeftovers_Click"/>

                        <TextBlock x:Name="LeftoverResultsText"
                                   Foreground="White"
                                   FontSize="15"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- STORAGE -->

            <Grid x:Name="StoragePage"
                  Visibility="Collapsed">

                <UniformGrid Columns="2">

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="Downloads Folder"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock x:Name="DownloadsSizeText"
                                       FontSize="48"
                                       FontWeight="Bold"
                                       Foreground="#4F8CFF"
                                       Margin="0,24,0,0"/>

                        </StackPanel>

                    </Border>

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="Largest Installed Apps"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,18"/>

                            <ScrollViewer Height="500">

                                <TextBlock x:Name="LargestAppsText"
                                           Foreground="#CBD5E1"
                                           FontSize="15"
                                           TextWrapping="Wrap"/>

                            </ScrollViewer>

                        </StackPanel>

                    </Border>

                </UniformGrid>

            </Grid>

            <!-- ACTIVITY -->

            <Grid x:Name="ActivityPage"
                  Visibility="Collapsed">

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Activity Feed"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,20"/>

                        <ScrollViewer Height="620">

                            <TextBlock x:Name="ActivityText"
                                       Foreground="#E2E8F0"
                                       FontSize="15"
                                       LineHeight="28"
                                       TextWrapping="Wrap"/>

                        </ScrollViewer>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Window>
