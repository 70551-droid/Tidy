&lt;Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Width="1850"
        Height="1060"
        MinWidth="1500"
        MinHeight="900"
        WindowStartupLocation="CenterScreen"
        Background="#070B14"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"&gt;

    &lt;Window.Resources&gt;

        &lt;SolidColorBrush x:Key="PrimaryBrush" Color="#4F8CFF"/&gt;
        &lt;SolidColorBrush x:Key="CardBrush" Color="#111827"/&gt;
        &lt;SolidColorBrush x:Key="SidebarBrush" Color="#0B1220"/&gt;
        &lt;SolidColorBrush x:Key="MutedBrush" Color="#94A3B8"/&gt;

        &lt;!-- CARD STYLE --&gt;
        &lt;Style x:Key="CardStyle" TargetType="Border"&gt;
            &lt;Setter Property="Background" Value="{StaticResource CardBrush}"/&gt;
            &lt;Setter Property="CornerRadius" Value="26"/&gt;
            &lt;Setter Property="Padding" Value="22"/&gt;
            &lt;Setter Property="Margin" Value="0,0,18,18"/&gt;
            &lt;Setter Property="BorderBrush" Value="#1E293B"/&gt;
            &lt;Setter Property="BorderThickness" Value="1"/&gt;
        &lt;/Style&gt;

        &lt;!-- SIDEBAR BUTTON --&gt;
        &lt;Style x:Key="SidebarButtonStyle" TargetType="Button"&gt;
            &lt;Setter Property="Foreground" Value="White"/&gt;
            &lt;Setter Property="FontSize" Value="15"/&gt;
            &lt;Setter Property="FontWeight" Value="SemiBold"/&gt;
            &lt;Setter Property="Height" Value="56"/&gt;
            &lt;Setter Property="Margin" Value="0,0,0,12"/&gt;
            &lt;Setter Property="Padding" Value="18,0"/&gt;
            &lt;Setter Property="Background" Value="Transparent"/&gt;
            &lt;Setter Property="BorderBrush" Value="Transparent"/&gt;
            &lt;Setter Property="Cursor" Value="Hand"/&gt;
            &lt;Setter Property="HorizontalContentAlignment" Value="Left"/&gt;
            &lt;Setter Property="Template"&gt;
                &lt;Setter.Value&gt;
                    &lt;ControlTemplate TargetType="Button"&gt;
                        &lt;Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"&gt;
                            &lt;ContentPresenter VerticalAlignment="Center" Margin="10,0"/&gt;
                        &lt;/Border&gt;
                        &lt;ControlTemplate.Triggers&gt;
                            &lt;Trigger Property="IsMouseOver" Value="True"&gt;
                                &lt;Setter TargetName="border" Property="Background" Value="#172554"/&gt;
                                &lt;Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/&gt;
                            &lt;/Trigger&gt;
                        &lt;/ControlTemplate.Triggers&gt;
                    &lt;/ControlTemplate&gt;
                &lt;/Setter.Value&gt;
            &lt;/Setter&gt;
        &lt;/Style&gt;

        &lt;!-- DATAGRID STYLES --&gt;
        &lt;Style TargetType="DataGrid"&gt;
            &lt;Setter Property="Background" Value="#111827"/&gt;
            &lt;Setter Property="Foreground" Value="White"/&gt;
            &lt;Setter Property="BorderBrush" Value="#1E293B"/&gt;
            &lt;Setter Property="BorderThickness" Value="1"/&gt;
            &lt;Setter Property="RowBackground" Value="#111827"/&gt;
            &lt;Setter Property="AlternatingRowBackground" Value="#0F172A"/&gt;
            &lt;Setter Property="GridLinesVisibility" Value="None"/&gt;
        &lt;/Style&gt;

    &lt;/Window.Resources&gt;

    &lt;Grid&gt;
        &lt;Grid.ColumnDefinitions&gt;
            &lt;ColumnDefinition Width="280"/&gt;
            &lt;ColumnDefinition Width="*"/&gt;
        &lt;/Grid.ColumnDefinitions&gt;

        &lt;!-- SIDEBAR --&gt;
        &lt;Border Background="{StaticResource SidebarBrush}"&gt;
            &lt;StackPanel Margin="18"&gt;
                &lt;TextBlock Text="Tidy" FontSize="38" FontWeight="Bold" Foreground="White" Margin="12,18,0,30"/&gt;

                &lt;Button x:Name="DashboardButton" Click="DashboardButton_Click" Style="{StaticResource SidebarButtonStyle}"&gt;
                    &lt;TextBlock Text="Dashboard"/&gt;
                &lt;/Button&gt;
                &lt;Button x:Name="AppsButton" Click="AppsButton_Click" Style="{StaticResource SidebarButtonStyle}"&gt;
                    &lt;TextBlock Text="Installed Apps"/&gt;
                &lt;/Button&gt;
                &lt;Button x:Name="CleanupButton" Click="CleanupButton_Click" Style="{StaticResource SidebarButtonStyle}"&gt;
                    &lt;TextBlock Text="Cleanup"/&gt;
                &lt;/Button&gt;
                &lt;Button x:Name="StorageButton" Click="StorageButton_Click" Style="{StaticResource SidebarButtonStyle}"&gt;
                    &lt;TextBlock Text="Storage"/&gt;
                &lt;/Button&gt;
                &lt;Button x:Name="ActivityButton" Click="ActivityButton_Click" Style="{StaticResource SidebarButtonStyle}"&gt;
                    &lt;TextBlock Text="Activity"/&gt;
                &lt;/Button&gt;
            &lt;/StackPanel&gt;
        &lt;/Border&gt;

        &lt;!-- MAIN CONTENT --&gt;
        &lt;Grid Grid.Column="1" Margin="28"&gt;

            &lt;!-- DASHBOARD --&gt;
            &lt;ScrollViewer x:Name="DashboardPage"&gt;
                &lt;StackPanel&gt;
                    &lt;TextBlock Text="Dashboard" FontSize="48" FontWeight="Bold" Foreground="White" Margin="0,0,0,28"/&gt;

                    &lt;UniformGrid Columns="4"&gt;
                        &lt;Border Style="{StaticResource CardStyle}"&gt;
                            &lt;StackPanel&gt;
                                &lt;TextBlock Text="CPU" Foreground="#94A3B8"/&gt;
                                &lt;TextBlock x:Name="CpuUsageText" Text="0%" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,12,0,0"/&gt;
                            &lt;/StackPanel&gt;
                        &lt;/Border&gt;

                        &lt;Border Style="{StaticResource CardStyle}"&gt;
                            &lt;StackPanel&gt;
                                &lt;TextBlock Text="RAM" Foreground="#94A3B8"/&gt;
                                &lt;TextBlock x:Name="RamUsageText" Text="0%" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,12,0,0"/&gt;
                                &lt;TextBlock x:Name="RamFigureText" Foreground="#CBD5E1" Margin="0,8,0,0"/&gt;
                            &lt;/StackPanel&gt;
                        &lt;/Border&gt;

                        &lt;Border Style="{StaticResource CardStyle}"&gt;
                            &lt;StackPanel&gt;
                                &lt;TextBlock Text="DISK" Foreground="#94A3B8"/&gt;
                                &lt;TextBlock x:Name="DiskUsageText" Text="0%" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,12,0,0"/&gt;
                                &lt;TextBlock x:Name="DiskFigureText" Foreground="#CBD5E1" Margin="0,8,0,0"/&gt;
                            &lt;/StackPanel&gt;
                        &lt;/Border&gt;

                        &lt;Border Style="{StaticResource CardStyle}"&gt;
                            &lt;StackPanel&gt;
                                &lt;TextBlock Text="INSTALLED APPS" Foreground="#94A3B8"/&gt;
                                &lt;TextBlock x:Name="InstalledCountText" Text="0" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,12,0,0"/&gt;
                            &lt;/StackPanel&gt;
                        &lt;/Border&gt;
                    &lt;/UniformGrid&gt;
                &lt;/StackPanel&gt;
            &lt;/ScrollViewer&gt;

            &lt;!-- APPS PAGE --&gt;
            &lt;Grid x:Name="AppsPage" Visibility="Collapsed"&gt;
                &lt;Border Style="{StaticResource CardStyle}"&gt;
                    &lt;Grid&gt;
                        &lt;Grid.RowDefinitions&gt;
                            &lt;RowDefinition Height="Auto"/&gt;
                            &lt;RowDefinition Height="*"/&gt;
                        &lt;/Grid.RowDefinitions&gt;

                        &lt;DockPanel Grid.Row="0" Margin="0,0,0,20"&gt;
                            &lt;TextBlock Text="Installed Applications" FontSize="32" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/&gt;
                            &lt;StackPanel Orientation="Horizontal" DockPanel.Dock="Right"&gt;
                                &lt;TextBox x:Name="SearchBox" Width="260" Height="42" Margin="0,0,14,0" Background="#0F172A" Foreground="White" BorderBrush="#1E293B" Padding="12,0" TextChanged="SearchBox_TextChanged"/&gt;
                                &lt;Button Content="Uninstall Selected" Width="190" Height="42" Background="#DC2626" Foreground="White" Click="UninstallSelected_Click"/&gt;
                            &lt;/StackPanel&gt;
                        &lt;/DockPanel&gt;

                        &lt;DataGrid x:Name="AppsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"/&gt;
                    &lt;/Grid&gt;
                &lt;/Border&gt;
            &lt;/Grid&gt;

            &lt;!-- CLEANUP PAGE --&gt;
            &lt;Grid x:Name="CleanupPage" Visibility="Collapsed"&gt;
                &lt;Border Style="{StaticResource CardStyle}"&gt;
                    &lt;StackPanel&gt;
                        &lt;TextBlock Text="Cleanup Engine" FontSize="34" FontWeight="Bold" Foreground="White"/&gt;
                        &lt;Button Content="Scan Leftovers" Width="220" Height="46" Margin="0,24,0,24" Background="#16A34A" Foreground="White" Click="ScanLeftovers_Click"/&gt;
                        &lt;TextBlock x:Name="LeftoverResultsText" Foreground="White" FontSize="15" TextWrapping="Wrap"/&gt;
                    &lt;/StackPanel&gt;
                &lt;/Border&gt;
            &lt;/Grid&gt;

            &lt;!-- STORAGE PAGE --&gt;
            &lt;Grid x:Name="StoragePage" Visibility="Collapsed"&gt;
                &lt;UniformGrid Columns="2"&gt;
                    &lt;Border Style="{StaticResource CardStyle}"&gt;
                        &lt;StackPanel&gt;
                            &lt;TextBlock Text="Downloads Folder" FontSize="28" FontWeight="Bold" Foreground="White"/&gt;
                            &lt;TextBlock x:Name="DownloadsSizeText" FontSize="48" FontWeight="Bold" Foreground="#4F8CFF" Margin="0,24,0,0"/&gt;
                        &lt;/StackPanel&gt;
                    &lt;/Border&gt;

                    &lt;Border Style="{StaticResource CardStyle}"&gt;
                        &lt;StackPanel&gt;
                            &lt;TextBlock Text="Largest Installed Apps" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,18"/&gt;
                            &lt;ScrollViewer Height="500"&gt;
                                &lt;TextBlock x:Name="LargestAppsText" Foreground="#CBD5E1" FontSize="15" TextWrapping="Wrap"/&gt;
                            &lt;/ScrollViewer&gt;
                        &lt;/StackPanel&gt;
                    &lt;/Border&gt;
                &lt;/UniformGrid&gt;
            &lt;/Grid&gt;

            &lt;!-- ACTIVITY PAGE --&gt;
            &lt;Grid x:Name="ActivityPage" Visibility="Collapsed"&gt;
                &lt;Border Style="{StaticResource CardStyle}"&gt;
                    &lt;StackPanel&gt;
                        &lt;TextBlock Text="Activity Feed" FontSize="34" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/&gt;
                        &lt;ScrollViewer Height="620"&gt;
                            &lt;TextBlock x:Name="ActivityText" Foreground="#E2E8F0" FontSize="15" TextWrapping="Wrap"/&gt;
                        &lt;/ScrollViewer&gt;
                    &lt;/StackPanel&gt;
                &lt;/Border&gt;
            &lt;/Grid&gt;

        &lt;/Grid&gt;
    &lt;/Grid&gt;
&lt;/Window&gt;