<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Width="1800"
        Height="1040"
        MinWidth="1500"
        MinHeight="900"
        WindowStartupLocation="CenterScreen"
        Background="#070B14"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>

        <!-- COLORS -->

        <SolidColorBrush x:Key="PrimaryBrush"
                         Color="#4F8CFF"/>

        <SolidColorBrush x:Key="CardBrush"
                         Color="#111827"/>

        <SolidColorBrush x:Key="SidebarBrush"
                         Color="#0B1220"/>

        <SolidColorBrush x:Key="BorderBrushCustom"
                         Color="#1F2937"/>

        <SolidColorBrush x:Key="MutedBrush"
                         Color="#94A3B8"/>

        <!-- BUTTON STYLE -->

        <Style x:Key="SidebarButtonStyle"
               TargetType="Button">

            <Setter Property="Height"
                    Value="54"/>

            <Setter Property="Margin"
                    Value="0,0,0,12"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Background"
                    Value="Transparent"/>

            <Setter Property="BorderBrush"
                    Value="Transparent"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="FontSize"
                    Value="15"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>

            <Setter Property="Padding"
                    Value="18,0,0,0"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">

                            <ContentPresenter VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#172554"/>

                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#2563EB"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <!-- CARD STYLE -->

        <Style x:Key="CardStyle"
               TargetType="Border">

            <Setter Property="Background"
                    Value="{StaticResource CardBrush}"/>

            <Setter Property="CornerRadius"
                    Value="24"/>

            <Setter Property="Padding"
                    Value="22"/>

            <Setter Property="BorderBrush"
                    Value="{StaticResource BorderBrushCustom}"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="Margin"
                    Value="0,0,18,18"/>

        </Style>

    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->

            <Border Background="{StaticResource SidebarBrush}"
                    BorderBrush="#111827"
                    BorderThickness="0,0,1,0">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- LOGO -->

                    <StackPanel Margin="28">

                        <Border Width="76"
                                Height="76"
                                CornerRadius="22"
                                Background="{StaticResource PrimaryBrush}">

                            <TextBlock Text="T"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                        </Border>

                        <TextBlock Text="Tidy"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,18,0,0"/>

                        <TextBlock Text="Modern Windows Intelligence"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   Margin="0,6,0,0"/>

                    </StackPanel>

                    <!-- NAV -->

                    <StackPanel Grid.Row="1"
                                Margin="18,10">

                        <Button Content="🏠 Dashboard"
                                Style="{StaticResource SidebarButtonStyle}"
                                Background="#172554"
                                BorderBrush="#2563EB"/>

                        <Button Content="📦 Installed Apps"
                                Style="{StaticResource SidebarButtonStyle}"/>

                        <Button Content="💾 Storage"
                                Style="{StaticResource SidebarButtonStyle}"/>

                        <Button Content="🧹 Cleanup"
                                Style="{StaticResource SidebarButtonStyle}"/>

                        <Button Content="⚡ Startup"
                                Style="{StaticResource SidebarButtonStyle}"/>

                        <Button Content="🧠 Recommendations"
                                Style="{StaticResource SidebarButtonStyle}"/>

                        <Button Content="📊 Activity"
                                Style="{StaticResource SidebarButtonStyle}"/>

                        <Button Content="⚙ Settings"
                                Style="{StaticResource SidebarButtonStyle}"/>

                    </StackPanel>

                    <!-- FOOTER -->

                    <Border Grid.Row="2"
                            Margin="18"
                            Background="#111827"
                            CornerRadius="18"
                            Padding="18"
                            BorderBrush="#1F2937"
                            BorderThickness="1">

                        <StackPanel>

                            <TextBlock Text="SYSTEM STATUS"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"/>

                            <TextBlock Text="Intelligence Engine Active"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       Margin="0,8,0,0"/>

                        </StackPanel>

                    </Border>

                </Grid>

            </Border>

            <!-- MAIN -->

            <StackPanel Grid.Column="1"
                        Margin="30">

                <!-- HEADER -->

                <DockPanel Margin="0,0,0,28">

                    <StackPanel>

                        <TextBlock Text="Dashboard"
                                   FontSize="46"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Advanced cleanup and system intelligence"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="15"
                                   Margin="0,6,0,0"/>

                    </StackPanel>

                    <Button Content="Refresh"
                            Width="140"
                            Height="46"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            Background="{StaticResource PrimaryBrush}"
                            Foreground="White"
                            BorderBrush="Transparent"
                            FontWeight="SemiBold"
                            Click="Refresh_Click"/>

                </DockPanel>

                <!-- STATS -->

                <UniformGrid Columns="4"
                             Margin="0,0,0,24">

                    <!-- CPU -->

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="CPU"
                                       Foreground="{StaticResource MutedBrush}"/>

                            <TextBlock x:Name="CpuUsageText"
                                       Text="0%"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,14,0,0"/>

                        </StackPanel>

                    </Border>

                    <!-- RAM -->

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="RAM"
                                       Foreground="{StaticResource MutedBrush}"/>

                            <TextBlock x:Name="RamUsageText"
                                       Text="0%"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,14,0,0"/>

                            <TextBlock x:Name="RamFigureText"
                                       Text="0 GB / 0 GB"
                                       Foreground="#CBD5E1"
                                       Margin="0,8,0,0"/>

                        </StackPanel>

                    </Border>

                    <!-- DISK -->

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="DISK"
                                       Foreground="{StaticResource MutedBrush}"/>

                            <TextBlock x:Name="DiskUsageText"
                                       Text="0%"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,14,0,0"/>

                            <TextBlock x:Name="DiskFigureText"
                                       Text="0 GB Free"
                                       Foreground="#CBD5E1"
                                       Margin="0,8,0,0"/>

                        </StackPanel>

                    </Border>

                    <!-- APPS -->

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="INSTALLED APPS"
                                       Foreground="{StaticResource MutedBrush}"/>

                            <TextBlock x:Name="InstalledCountText"
                                       Text="0"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,14,0,0"/>

                        </StackPanel>

                    </Border>

                </UniformGrid>

                <!-- APPS -->

                <Border Style="{StaticResource CardStyle}">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="420"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,0,0,18">

                            <TextBlock Text="Installed Applications"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBox x:Name="SearchBox"
                                     Width="280"
                                     Height="40"
                                     DockPanel.Dock="Right"
                                     TextChanged="SearchBox_TextChanged"
                                     Background="#0F172A"
                                     Foreground="White"
                                     BorderBrush="#1E293B"
                                     Padding="12,0"/>

                        </DockPanel>

                        <DataGrid x:Name="AppsGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  Background="#111827"
                                  Foreground="White"
                                  BorderThickness="0"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  RowBackground="#111827"
                                  AlternatingRowBackground="#0F172A"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <Button Grid.Row="2"
                                Content="Batch Uninstall Selected"
                                Width="250"
                                Height="42"
                                Margin="0,18,0,0"
                                HorizontalAlignment="Left"
                                Background="#DC2626"
                                Foreground="White"
                                BorderBrush="Transparent"
                                Click="BatchUninstall_Click"/>

                    </Grid>

                </Border>

                <!-- INTELLIGENCE -->

                <UniformGrid Columns="3">

                    <!-- DOWNLOADS -->

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="Downloads"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock x:Name="DownloadsSizeText"
                                       FontSize="38"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,18,0,0"/>

                        </StackPanel>

                    </Border>

                    <!-- LARGEST -->

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="Largest Apps"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <ScrollViewer Height="220"
                                          Margin="0,18,0,0">

                                <TextBlock x:Name="LargestAppsText"
                                           Foreground="#D1D5DB"
                                           TextWrapping="Wrap"/>

                            </ScrollViewer>

                        </StackPanel>

                    </Border>

                    <!-- RECOMMENDATIONS -->

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="Recommendations"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <ScrollViewer Height="220"
                                          Margin="0,18,0,0">

                                <TextBlock x:Name="RecommendationsText"
                                           Foreground="#D1D5DB"
                                           TextWrapping="Wrap"/>

                            </ScrollViewer>

                        </StackPanel>

                    </Border>

                </UniformGrid>

                <!-- CLEANUP -->

                <UniformGrid Columns="2">

                    <!-- LEFTOVERS -->

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="Leftover Cleanup"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <Button Content="Scan Leftovers"
                                    Height="44"
                                    Margin="0,18,0,18"
                                    Background="#16A34A"
                                    Foreground="White"
                                    BorderBrush="Transparent"
                                    Click="ScanLeftovers_Click"/>

                            <ScrollViewer Height="240">

                                <TextBlock x:Name="LeftoverResultsText"
                                           Foreground="#D1D5DB"
                                           TextWrapping="Wrap"/>

                            </ScrollViewer>

                        </StackPanel>

                    </Border>

                    <!-- STORE -->

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="Microsoft Store Apps"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <ScrollViewer Height="300"
                                          Margin="0,18,0,0">

                                <TextBlock x:Name="StoreAppsText"
                                           Foreground="#D1D5DB"
                                           TextWrapping="Wrap"/>

                            </ScrollViewer>

                        </StackPanel>

                    </Border>

                </UniformGrid>

                <!-- ACTIVITY -->

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Activity"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <ScrollViewer Height="240"
                                      Margin="0,18,0,0">

                            <TextBlock x:Name="ActivityText"
                                       Foreground="#D1D5DB"
                                       TextWrapping="Wrap"/>

                        </ScrollViewer>

                    </StackPanel>

                </Border>

            </StackPanel>

        </Grid>

    </ScrollViewer>

</Window>
