<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Height="1020"
        Width="1720"
        WindowStartupLocation="CenterScreen"
        Background="#0B1020">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Background="#070B16"
                BorderBrush="#1B2236"
                BorderThickness="0,0,1,0">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LOGO -->
                <StackPanel Margin="24,28,24,24">

                    <Border Width="62"
                            Height="62"
                            CornerRadius="18"
                            Background="#1B5CFF">

                        <TextBlock Text="T"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                    </Border>

                    <TextBlock Text="Tidy"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,16,0,0"/>

                    <TextBlock Text="Windows 11 Cleanup"
                               Foreground="#7E8AA8"
                               FontSize="13"
                               Margin="0,4,0,0"/>

                </StackPanel>

                <!-- NAV -->
                <StackPanel Grid.Row="1"
                            Margin="16,10,16,10">

                    <StackPanel.Resources>

                        <Style TargetType="Button">

                            <Setter Property="Height" Value="52"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="#11182D"/>
                            <Setter Property="BorderBrush" Value="#1D2945"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontSize" Value="15"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Padding" Value="18,0,0,0"/>
                            <Setter Property="Cursor" Value="Hand"/>

                            <Style.Triggers>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1B5CFF"/>
                                    <Setter Property="BorderBrush" Value="#4A7DFF"/>
                                </Trigger>

                            </Style.Triggers>

                        </Style>

                    </StackPanel.Resources>

                    <Button Content="Dashboard"/>
                    <Button Content="Installed Apps"/>
                    <Button Content="Startup Apps"/>
                    <Button Content="Storage Analysis"/>
                    <Button Content="Temp Cleaner"/>
                    <Button Content="Activity"/>
                    <Button Content="Settings"/>

                </StackPanel>

                <!-- FOOTER -->
                <Border Grid.Row="2"
                        Margin="16"
                        Padding="16"
                        CornerRadius="16"
                        Background="#11182D"
                        BorderBrush="#1D2945"
                        BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="System Status"
                                   Foreground="#8FA1CC"
                                   FontSize="12"/>

                        <TextBlock Text="Tidy is running normally"
                                   Foreground="White"
                                   FontSize="14"
                                   Margin="0,6,0,0"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Border>

        <!-- MAIN -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">

            <Grid Margin="28">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="500"/>
                    <RowDefinition Height="280"/>
                    <RowDefinition Height="300"/>
                    <RowDefinition Height="300"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <DockPanel>

                    <StackPanel>

                        <TextBlock Text="Dashboard"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Windows cleanup and optimization overview."
                                   Foreground="#95A1BE"
                                   FontSize="15"
                                   Margin="0,6,0,0"/>

                    </StackPanel>

                    <Button Content="Refresh"
                            Width="130"
                            Height="42"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            Click="Refresh_Click"
                            Background="#1B5CFF"
                            Foreground="White"
                            BorderBrush="#4A7DFF"/>

                </DockPanel>

                <!-- TOP CARDS -->
                <Grid Grid.Row="1"
                      Margin="0,30,0,30">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="#11182D"
                            CornerRadius="18"
                            Padding="24"
                            Margin="0,0,20,0">

                        <StackPanel>

                            <TextBlock Text="CLEANUP SCORE"
                                       Foreground="#8FA1CC"
                                       FontSize="13"/>

                            <TextBlock x:Name="CleanupScoreText"
                                       Text="0"
                                       FontSize="56"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,12,0,0"/>

                            <TextBlock x:Name="CleanupStatusText"
                                       Text="Analyzing"
                                       FontSize="24"
                                       Foreground="#FF4D6D"
                                       Margin="0,10,0,0"/>

                        </StackPanel>

                    </Border>

                    <Border Grid.Column="1"
                            Background="#11182D"
                            CornerRadius="18"
                            Padding="24"
                            Margin="0,0,20,0">

                        <StackPanel>

                            <TextBlock Text="INSTALLED APPS"
                                       Foreground="#8FA1CC"
                                       FontSize="13"/>

                            <TextBlock x:Name="InstalledCountText"
                                       Text="0"
                                       FontSize="44"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,18,0,0"/>

                        </StackPanel>

                    </Border>

                    <Border Grid.Column="2"
                            Background="#11182D"
                            CornerRadius="18"
                            Padding="24">

                        <StackPanel>

                            <TextBlock Text="DISK USAGE"
                                       Foreground="#8FA1CC"
                                       FontSize="13"/>

                            <TextBlock x:Name="DiskUsageText"
                                       Text="0 GB"
                                       FontSize="44"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,18,0,0"/>

                        </StackPanel>

                    </Border>

                </Grid>

                <!-- APPS -->
                <Border Grid.Row="2"
                        Background="#11182D"
                        CornerRadius="18"
                        Padding="18"
                        Margin="0,0,0,24">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- TOP -->
                        <DockPanel Margin="0,0,0,18">

                            <TextBlock Text="Installed Applications"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBox x:Name="SearchBox"
                                     Width="260"
                                     Height="38"
                                     DockPanel.Dock="Right"
                                     TextChanged="SearchBox_TextChanged"
                                     Background="#182038"
                                     Foreground="White"
                                     BorderBrush="#2A3B66"/>

                        </DockPanel>

                        <!-- GRID -->
                        <DataGrid x:Name="AppsGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="#11182D"
                                  Foreground="White"
                                  RowBackground="#11182D"
                                  AlternatingRowBackground="#182038">

                            <DataGrid.Resources>

                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#182038"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Height" Value="42"/>
                                </Style>

                            </DataGrid.Resources>

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Application"
                                                    Width="*"
                                                    Binding="{Binding Name}"/>

                                <DataGridTextColumn Header="Publisher"
                                                    Width="220"
                                                    Binding="{Binding Publisher}"/>

                                <DataGridTextColumn Header="Size"
                                                    Width="120"
                                                    Binding="{Binding Size}"/>

                                <DataGridTextColumn Header="Location"
                                                    Width="260"
                                                    Binding="{Binding InstallLocation}"/>

                                <DataGridTextColumn Header="Type"
                                                    Width="120"
                                                    Binding="{Binding UninstallType}"/>

                                <DataGridTemplateColumn Header="Action"
                                                        Width="140">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <Button Content="Uninstall"
                                                    Height="32"
                                                    Background="#D83B3B"
                                                    Foreground="White"
                                                    Click="UninstallButton_Click"/>

                                        </DataTemplate>

                                    </DataGridTemplateColumn.CellTemplate>

                                </DataGridTemplateColumn>

                            </DataGrid.Columns>

                        </DataGrid>

                        <!-- BOTTOM ACTIONS -->
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    Margin="0,18,0,0">

                            <Button Content="Batch Uninstall Selected"
                                    Width="240"
                                    Height="42"
                                    Background="#B91C1C"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Click="BatchUninstall_Click"/>

                        </StackPanel>

                    </Grid>

                </Border>

                <!-- ANALYSIS -->
                <Grid Grid.Row="3"
                      Margin="0,0,0,24">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LARGEST APPS -->
                    <Border Background="#11182D"
                            CornerRadius="18"
                            Padding="18"
                            Margin="0,0,12,0">

                        <StackPanel>

                            <TextBlock Text="Largest Applications"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,16"/>

                            <TextBlock x:Name="LargestAppsText"
                                       Foreground="#D6DCEF"
                                       FontSize="15"
                                       TextWrapping="Wrap"/>

                        </StackPanel>

                    </Border>

                    <!-- CLEANUP SUGGESTIONS -->
                    <Border Grid.Column="1"
                            Background="#11182D"
                            CornerRadius="18"
                            Padding="18"
                            Margin="12,0,0,0">

                        <StackPanel>

                            <TextBlock Text="Cleanup Suggestions"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,16"/>

                            <TextBlock x:Name="CleanupSuggestionsText"
                                       Foreground="#D6DCEF"
                                       FontSize="15"
                                       TextWrapping="Wrap"/>

                        </StackPanel>

                    </Border>

                </Grid>

                <!-- STARTUP + TEMP -->
                <Grid Grid.Row="4"
                      Margin="0,0,0,24">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- STARTUP -->
                    <Border Background="#11182D"
                            CornerRadius="18"
                            Padding="18"
                            Margin="0,0,12,0">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Startup Applications"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <ListBox x:Name="StartupListBox"
                                     Grid.Row="1"
                                     Margin="0,18,0,18"
                                     Background="#182038"
                                     Foreground="White"
                                     BorderThickness="0"/>

                            <Button Grid.Row="2"
                                    Content="Disable Selected Startup App"
                                    Height="40"
                                    Background="#1B5CFF"
                                    Foreground="White"
                                    Click="DisableStartup_Click"/>

                        </Grid>

                    </Border>

                    <!-- TEMP -->
                    <Border Grid.Column="1"
                            Background="#11182D"
                            CornerRadius="18"
                            Padding="18"
                            Margin="12,0,0,0">

                        <StackPanel>

                            <TextBlock Text="Temp Cleaner"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="Safely remove temporary Windows files."
                                       Foreground="#9FB0D0"
                                       Margin="0,12,0,18"/>

                            <Button Content="Clean Temp Files"
                                    Height="44"
                                    Background="#16A34A"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Click="CleanTemp_Click"/>

                            <TextBlock x:Name="TempCleanerResultText"
                                       Margin="0,20,0,0"
                                       Foreground="#D6DCEF"
                                       FontSize="15"
                                       TextWrapping="Wrap"/>

                        </StackPanel>

                    </Border>

                </Grid>

                <!-- ACTIVITY -->
                <Border Grid.Row="5"
                        Background="#11182D"
                        CornerRadius="18"
                        Padding="18">

                    <StackPanel>

                        <TextBlock Text="Activity"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,18"/>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">

                            <TextBlock x:Name="ActivityText"
                                       Foreground="#D6DCEF"
                                       FontSize="15"
                                       TextWrapping="Wrap"/>

                        </ScrollViewer>

                    </StackPanel>

                </Border>

            </Grid>

        </ScrollViewer>

    </Grid>
</Window>
