<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy 2.0"
        Height="900"
        Width="1500"
        WindowStartupLocation="CenterScreen"
        Background="#0B1120">

    <Window.Resources>

        <SolidColorBrush x:Key="SidebarBrush" Color="#111827"/>
        <SolidColorBrush x:Key="MainBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="CardBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6"/>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="12,6"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource MainBrush}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}">

            <StackPanel>

                <TextBlock Text="Tidy"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="Bold"
                           Margin="20"/>

                <Button Content="Dashboard"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="DashboardButton_Click"/>

                <Button Content="Installed Apps"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="AppsButton_Click"/>

                <Button Content="Cleanup"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="CleanupButton_Click"/>

                <Button Content="Storage"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="StorageButton_Click"/>

                <Button Content="Activity"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="ActivityButton_Click"/>

            </StackPanel>

        </Border>

        <!-- MAIN CONTENT -->

        <Grid Grid.Column="1">

            <!-- DASHBOARD -->

            <ScrollViewer x:Name="DashboardPage">

                <StackPanel Margin="30">

                    <TextBlock Text="Dashboard"
                               Foreground="White"
                               FontSize="38"
                               FontWeight="Bold"
                               Margin="0,0,0,25"/>

                    <WrapPanel>

                        <!-- CPU -->

                        <Border Width="260"
                                Height="160"
                                Background="{StaticResource CardBrush}"
                                CornerRadius="18"
                                Margin="10">

                            <StackPanel Margin="20">

                                <TextBlock Text="CPU Usage"
                                           Foreground="White"
                                           FontSize="18"/>

                                <TextBlock x:Name="CpuText"
                                           Text="0%"
                                           Foreground="#4ADE80"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Margin="0,15,0,0"/>

                            </StackPanel>

                        </Border>

                        <!-- RAM -->

                        <Border Width="260"
                                Height="160"
                                Background="{StaticResource CardBrush}"
                                CornerRadius="18"
                                Margin="10">

                            <StackPanel Margin="20">

                                <TextBlock Text="RAM Usage"
                                           Foreground="White"
                                           FontSize="18"/>

                                <TextBlock x:Name="RamText"
                                           Text="0 GB"
                                           Foreground="#60A5FA"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Margin="0,15,0,0"/>

                            </StackPanel>

                        </Border>

                        <!-- DISK -->

                        <Border Width="260"
                                Height="160"
                                Background="{StaticResource CardBrush}"
                                CornerRadius="18"
                                Margin="10">

                            <StackPanel Margin="20">

                                <TextBlock Text="Disk Usage"
                                           Foreground="White"
                                           FontSize="18"/>

                                <TextBlock x:Name="DiskText"
                                           Text="0 GB"
                                           Foreground="#FACC15"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Margin="0,15,0,0"/>

                            </StackPanel>

                        </Border>

                    </WrapPanel>

                </StackPanel>

            </ScrollViewer>

            <!-- APPS PAGE -->

            <Grid x:Name="AppsPage"
                  Visibility="Collapsed">

                <StackPanel Margin="30">

                    <TextBlock Text="Installed Applications"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <TextBox x:Name="SearchBox"
                             Height="40"
                             FontSize="16"
                             Margin="0,0,0,20"
                             TextChanged="SearchBox_TextChanged"/>

                    <DataGrid x:Name="AppsGrid"
          Height="650"
          AutoGenerateColumns="True"
          Background="#1E293B"
          Foreground="White"
          BorderBrush="#334155"
          RowBackground="#1E293B"
          AlternatingRowBackground="#243041"
          GridLinesVisibility="None"
          HeadersVisibility="Column"
          FontSize="14"
          RowHeight="38"
          CanUserAddRows="False"/>


                </StackPanel>

            </Grid>

            <!-- CLEANUP PAGE -->

            <Grid x:Name="CleanupPage"
                  Visibility="Collapsed">

                <StackPanel Margin="30">

                    <TextBlock Text="Cleanup Engine"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               Margin="0,0,0,25"/>

                    <WrapPanel>

                        <Button Content="Clean Temp Files"
                                Width="200"
                                Height="55"
                                Margin="10"
                                Background="#16A34A"
                                Foreground="White"
                                Click="CleanTemp_Click"/>

                        <Button Content="Clean Recycle Bin"
                                Width="200"
                                Height="55"
                                Margin="10"
                                Background="#2563EB"
                                Foreground="White"
                                Click="CleanRecycle_Click"/>

                    </WrapPanel>

                    <TextBlock x:Name="CleanupStatusText"
                               Text="Awaiting action..."
                               Foreground="White"
                               FontSize="18"
                               Margin="15"/>

                </StackPanel>

            </Grid>

            <!-- STORAGE PAGE -->

            <Grid x:Name="StoragePage"
                  Visibility="Collapsed">

                <StackPanel Margin="30">

                    <TextBlock Text="Storage Analyzer"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               Margin="0,0,0,25"/>

                    <Border Background="{StaticResource CardBrush}"
                            CornerRadius="18"
                            Padding="20"
                            Width="400">

                        <StackPanel>

                            <TextBlock Text="Drive C:"
                                       Foreground="White"
                                       FontSize="20"/>

                            <TextBlock x:Name="StorageText"
                                       Text="Scanning..."
                                       Foreground="#60A5FA"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Margin="0,15,0,0"/>

                        </StackPanel>

                    </Border>

                </StackPanel>

            </Grid>

            <!-- ACTIVITY PAGE -->

            <Grid x:Name="ActivityPage"
                  Visibility="Collapsed">

                <StackPanel Margin="30">

                    <TextBlock Text="Activity Center"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               Margin="0,0,0,25"/>

                    <ListBox x:Name="ActivityList"
                             Height="650"
                             Background="#1E293B"
                             Foreground="White"/>

                </StackPanel>

            </Grid>

        </Grid>

    </Grid>

</Window>