<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy - System Cleanup Utility"
        Height="900"
        Width="1500"
        MinHeight="600"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#070B14"
        Icon="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect fill='%232563EB' width='100' height='100'/><text x='50' y='70' font-size='60' font-weight='bold' fill='white' text-anchor='middle'>T</text></svg>">

    <Window.Resources>

        <SolidColorBrush x:Key="SidebarBrush" Color="#0B1220"/>
        <SolidColorBrush x:Key="CardBrush" Color="#111827"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="BorderBrushCustom" Color="#1E293B"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="SuccessHoverBrush" Color="#15803D"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="WarningHoverBrush" Color="#B91C1C"/>
        <SolidColorBrush x:Key="InfoBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="InfoHoverBrush" Color="#1D4ED8"/>

        <!-- Navigation Button Style with Hover Effect -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Action Button Style for Cleanup Operations -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="15,10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Stat Card Style -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadow BlurRadius="10" Opacity="0.2" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrushCustom}"
                BorderThickness="0,0,1,0">

            <StackPanel VerticalAlignment="Top">

                <TextBlock Text="Tidy"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="34"
                           FontWeight="Bold"
                           Margin="20,25,20,10"
                           ToolTip="System Cleanup Utility"/>

                <TextBlock Text="v1.0"
                           Foreground="#64748B"
                           FontSize="11"
                           Margin="20,0,20,20"/>

                <Separator Background="{StaticResource BorderBrushCustom}" Margin="10,10"/>

                <TextBlock Text="Navigation"
                           Foreground="#64748B"
                           FontSize="12"
                           Margin="20,15,20,10"
                           FontWeight="SemiBold"/>

                <Button x:Name="DashboardButton"
                        Content="📊 Dashboard"
                        Style="{StaticResource NavButtonStyle}"
                        Click="DashboardButton_Click"/>

                <Button x:Name="AppsButton"
                        Content="📦 Installed Apps"
                        Style="{StaticResource NavButtonStyle}"
                        Click="AppsButton_Click"/>

                <Button x:Name="CleanupButton"
                        Content="🧹 Cleanup Engine"
                        Style="{StaticResource NavButtonStyle}"
                        Click="CleanupButton_Click"/>

                <Button x:Name="StorageButton"
                        Content="💾 Storage"
                        Style="{StaticResource NavButtonStyle}"
                        Click="StorageButton_Click"/>

                <Button x:Name="ActivityButton"
                        Content="⚙️ Activity"
                        Style="{StaticResource NavButtonStyle}"
                        Click="ActivityButton_Click"/>

                <Separator Background="{StaticResource BorderBrushCustom}" Margin="10,15"/>

                <TextBlock Text="Tools"
                           Foreground="#64748B"
                           FontSize="12"
                           Margin="20,15,20,10"
                           FontWeight="SemiBold"/>

                <Button Content="🔄 Startup Apps"
                        Style="{StaticResource NavButtonStyle}"
                        Click="StartupButton_Click"/>

                <Button Content="🔍 Duplicate Finder"
                        Style="{StaticResource NavButtonStyle}"
                        Click="DuplicateButton_Click"/>

                <Button Content="🎨 Themes"
                        Style="{StaticResource NavButtonStyle}"
                        Click="ThemesButton_Click"/>

                <Button Content="🤖 AI Tools"
                        Style="{StaticResource NavButtonStyle}"
                        Click="AiButton_Click"/>

            </StackPanel>

        </Border>

        <!-- MAIN AREA -->

        <Grid Grid.Column="1">

            <!-- DASHBOARD PAGE -->

            <ScrollViewer x:Name="DashboardPage"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel Margin="25">

                    <TextBlock Text="Dashboard"
                               Foreground="White"
                               FontSize="40"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="System Performance Metrics"
                               Foreground="#9CA3AF"
                               FontSize="14"
                               Margin="0,0,0,25"/>

                    <!-- Stats Cards -->
                    <WrapPanel>

                        <!-- CPU Usage Card -->
                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <TextBlock Text="CPU Usage"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10"/>

                                <TextBlock x:Name="CpuUsageText"
                                           Text="0%"
                                           Foreground="#4ADE80"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Margin="0,0,0,5"/>

                                <ProgressBar x:Name="CpuProgressBar"
                                             Height="4"
                                             Background="#1E293B"
                                             Foreground="#4ADE80"
                                             Value="0"
                                             Maximum="100"/>
                            </StackPanel>
                        </Border>

                        <!-- RAM Usage Card -->
                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <TextBlock Text="RAM Usage"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10"/>

                                <TextBlock x:Name="RamFigureText"
                                           Text="0 GB"
                                           Foreground="#60A5FA"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Margin="0,0,0,5"/>

                                <ProgressBar x:Name="RamProgressBar"
                                             Height="4"
                                             Background="#1E293B"
                                             Foreground="#60A5FA"
                                             Value="0"
                                             Maximum="100"/>
                            </StackPanel>
                        </Border>

                        <!-- Disk Usage Card -->
                        <Border Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Disk Usage"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10"/>

                                <TextBlock x:Name="DiskUsageText"
                                           Text="0 GB"
                                           Foreground="#FACC15"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Margin="0,0,0,5"/>

                                <ProgressBar x:Name="DiskProgressBar"
                                             Height="4"
                                             Background="#1E293B"
                                             Foreground="#FACC15"
                                             Value="0"
                                             Maximum="100"/>
                            </StackPanel>
                        </Border>

                    </WrapPanel>

                    <!-- Last Updated -->
                    <TextBlock x:Name="LastUpdatedText"
                               Text="Last updated: just now"
                               Foreground="#64748B"
                               FontSize="12"
                               Margin="0,30,0,0"/>

                </StackPanel>

            </ScrollViewer>

            <!-- APPS PAGE -->

            <ScrollViewer x:Name="AppsPage"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel Margin="25">

                    <TextBlock Text="Installed Applications"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Manage and search through installed software"
                               Foreground="#9CA3AF"
                               FontSize="14"
                               Margin="0,0,0,20"/>

                    <!-- Search Box -->
                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrushCustom}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,15">
                        <TextBox x:Name="SearchBox"
                                 Height="45"
                                 FontSize="16"
                                 Background="Transparent"
                                 Foreground="White"
                                 CaretBrush="White"
                                 BorderThickness="0"
                                 Padding="15,12"
                                 TextChanged="SearchBox_TextChanged">
                            <TextBox.Foreground>
                                <SolidColorBrush Color="White" Opacity="0.7"/>
                            </TextBox.Foreground>
                        </TextBox>
                    </Border>

                    <TextBlock x:Name="InstalledCountText"
                               Text="0 Apps Installed"
                               Foreground="#9CA3AF"
                               FontSize="14"
                               Margin="0,0,0,15"
                               FontWeight="SemiBold"/>

                    <!-- Apps DataGrid -->
                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrushCustom}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="1">
                        <DataGrid x:Name="AppsGrid"
                                  Height="600"
                                  AutoGenerateColumns="True"
                                  Background="#111827"
                                  Foreground="White"
                                  BorderThickness="0"
                                  RowBackground="#111827"
                                  AlternatingRowBackground="#0F1419"
                                  HeadersVisibility="Column">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                </Style>
                            </DataGrid.Resources>
                        </DataGrid>
                    </Border>

                </StackPanel>

            </ScrollViewer>

            <!-- CLEANUP PAGE -->

            <ScrollViewer x:Name="CleanupPage"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel Margin="25">

                    <TextBlock Text="Cleanup Engine"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Optimize your system by cleaning unnecessary files"
                               Foreground="#9CA3AF"
                               FontSize="14"
                               Margin="0,0,0,25"/>

                    <!-- Warning Banner -->
                    <Border Background="#7F1D1D"
                            BorderBrush="#DC2626"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,0,0,25">
                        <StackPanel>
                            <TextBlock Text="⚠️ Warning"
                                       Foreground="#FCA5A5"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="These operations will permanently delete files. Always backup important data before proceeding."
                                       Foreground="#FEE2E2"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Cleanup Actions -->
                    <WrapPanel Margin="0,10,0,25">

                        <Button Content="🗑️ Clean Temp Files"
                                Width="200"
                                Height="60"
                                Margin="10"
                                Background="{StaticResource SuccessBrush}"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="CleanTemp_Click">
                            <Button.Resources>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SuccessHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Content="🗑️ Empty Recycle Bin"
                                Width="200"
                                Height="60"
                                Margin="10"
                                Background="{StaticResource InfoBrush}"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="CleanRecycle_Click">
                            <Button.Resources>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource InfoHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Content="⚡ Boost Mode"
                                Width="200"
                                Height="60"
                                Margin="10"
                                Background="{StaticResource WarningBrush}"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="BoostMode_Click">
                            <Button.Resources>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource WarningHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                        </Button>

                    </WrapPanel>

                    <!-- Result Display -->
                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrushCustom}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Operation Status"
                                       Foreground="#9CA3AF"
                                       FontSize="12"
                                       Margin="0,0,0,10"/>

                            <TextBlock x:Name="CleanupResultText"
                                       Text="Awaiting cleanup operation..."
                                       Foreground="White"
                                       FontSize="16"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>

                            <!-- Progress Bar -->
                            <ProgressBar x:Name="CleanupProgressBar"
                                         Height="6"
                                         Background="#1E293B"
                                         Foreground="{StaticResource AccentBrush}"
                                         Value="0"
                                         Maximum="100"
                                         Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </ScrollViewer>

            <!-- STORAGE PAGE -->

            <ScrollViewer x:Name="StoragePage"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel Margin="25">

                    <TextBlock Text="Storage Analyzer"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Monitor folder sizes and storage usage"
                               Foreground="#9CA3AF"
                               FontSize="14"
                               Margin="0,0,0,25"/>

                    <!-- Downloads Folder -->
                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrushCustom}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,15">

                        <StackPanel>

                            <TextBlock Text="📁 Downloads Folder"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <TextBlock x:Name="DownloadsSizeText"
                                       Text="Scanning..."
                                       Foreground="#60A5FA"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <ProgressBar x:Name="DownloadsProgressBar"
                                         Height="6"
                                         Background="#1E293B"
                                         Foreground="#60A5FA"
                                         Value="0"
                                         Maximum="100"
                                         Margin="0,0,0,10"/>

                            <TextBlock x:Name="DownloadsDetailText"
                                       Text="Calculating..."
                                       Foreground="#9CA3AF"
                                       FontSize="13"/>

                        </StackPanel>

                    </Border>

                    <!-- C Drive Status -->
                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrushCustom}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="💾 C: Drive Usage"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <TextBlock x:Name="CDriveText"
                                       Text="Loading..."
                                       Foreground="#FACC15"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <ProgressBar x:Name="CDriveProgressBar"
                                         Height="6"
                                         Background="#1E293B"
                                         Foreground="#FACC15"
                                         Value="0"
                                         Maximum="100"
                                         Margin="0,0,0,10"/>

                            <TextBlock x:Name="CDriveDetailText"
                                       Text="Calculating..."
                                       Foreground="#9CA3AF"
                                       FontSize="13"/>

                        </StackPanel>

                    </Border>

                </StackPanel>

            </ScrollViewer>

            <!-- ACTIVITY PAGE -->

            <ScrollViewer x:Name="ActivityPage"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel Margin="25">

                    <TextBlock Text="Activity Center"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="View startup applications and system processes"
                               Foreground="#9CA3AF"
                               FontSize="14"
                               Margin="0,0,0,20"/>

                    <!-- Startup Apps List -->
                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrushCustom}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="1">

                        <ListBox x:Name="StartupGrid"
                                 Height="500"
                                 Background="#111827"
                                 Foreground="White"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0F1419"
                                            Padding="15"
                                            Margin="0,5"
                                            CornerRadius="6"
                                            BorderBrush="#1E293B"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding Command}"
                                                       Foreground="#9CA3AF"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Opacity="0.8"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </Border>

                    <TextBlock x:Name="StartupCountText"
                               Text="Startup items loaded"
                               Foreground="#64748B"
                               FontSize="12"
                               Margin="0,15,0,0"/>

                </StackPanel>

            </ScrollViewer>

        </Grid>

    </Grid>

</Window>
