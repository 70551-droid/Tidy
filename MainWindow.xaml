<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy" Height="500" Width="800">

    <Grid Margin="10">
        <StackPanel>

            <TextBlock Text="Tidy" FontSize="26" FontWeight="Bold" Margin="0,0,0,10"/>

            <ListBox x:Name="AppsList" Height="300"/>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="Refresh" Width="100" Margin="0,0,10,0" Click="Refresh_Click"/>
                <Button Content="Uninstall" Width="100" Click="Uninstall_Click"/>
            </StackPanel>

            <TextBox x:Name="Logs" Height="100" Margin="0,10,0,0"
                     IsReadOnly="True" AcceptsReturn="True"/>
        </StackPanel>
    </Grid>
</Window>
