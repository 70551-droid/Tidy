<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Height="900"
        Width="1600"
        MinHeight="800"
        MinWidth="1400"
        Background="#070B14"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- COLORS -->

        <SolidColorBrush x:Key="SidebarBrush" Color="#0B1220"/>
        <SolidColorBrush x:Key="CardBrush" Color="#111827"/>
        <SolidColorBrush x:Key="BorderBrushCustom" Color="#1E293B"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>

        <!-- CARD STYLE -->

        <Style x:Key="CardStyle"
               TargetType="Border">

            <Setter Property="Background"
                    Value="{StaticResource CardBrush}"/>

            <Setter Property="CornerRadius"
                    Value="24"/>

            <Setter Property="Padding"
                    Value="20"/>

            <Setter Property="Margin"
                    Value="0,0,20,20"/>

            <Setter Property="BorderBrush"
                    Value="{StaticResource BorderBrushCustom}"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

        </Style>

        <!-- SIDEBAR BUTTON -->

        <Style x:Key="SidebarButtonStyle"
               TargetType="Button">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="FontSize"
                    Value="16"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Height"
                    Value="56"/>

            <Setter Property="Margin"
                    Value="0,0,0,12"/>

            <Setter Property="Background"
                    Value="Transparent"/>

            <Setter Property="BorderBrush"
                    Value="Transparent"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>

            <Setter Property="Padding"
                    Value="20,0"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">

                            <ContentPresenter VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#172554"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}">

            <StackPanel Margin="18">

                <TextBlock Text="Tidy"
                           FontSize="40"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="10,20,0,40"/>

                <Button x:Name="DashboardButton"
                        Content="Dashboard"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="DashboardButton_Click"/>

                <Button x:Name="AppsButton"
                        Content="Installed Apps"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="AppsButton_Click"/>

                <Button x:Name="CleanupButton"
                        Content="Cleanup"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="CleanupButton_Click"/>

                <Button x:Name="StorageButton"
                        Content="Storage"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="StorageButton_Click"/>

                <Button x:Name="ActivityButton"
                        Content="Activity"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="ActivityButton_Click"/>

            </StackPanel>

        </Border>

        <!-- MAIN CONTENT -->

        <Grid Grid.Column="1"
              Margin="24">

            <!-- DASHBOARD -->

            <ScrollViewer x:Name="DashboardPage">

                <StackPanel>

                    <TextBlock Text="Dashboard"
                               FontSize="44"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,24"/>

                    <UniformGrid Columns="4">

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="CPU"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="CpuUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,10,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="RAM"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="RamUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,10,0,0"/>

                                <TextBlock x:Name="RamFigureText"
                                           Foreground="#CBD5E1"
                                           Margin="0,8,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="DISK"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="DiskUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,10,0,0"/>

                                <TextBlock x:Name="DiskFigureText"
                                           Foreground="#CBD5E1"
                                           Margin="0,8,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="INSTALLED APPS"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="InstalledCountText"
                                           Text="0"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,10,0,0"/>

                            </StackPanel>

                        </Border>

                    </UniformGrid>

                </StackPanel>

            </ScrollViewer>

            <!-- APPS PAGE -->

            <Grid x:Name="AppsPage"
                  Visibility="Collapsed">

                <Border Style="{StaticResource CardStyle}">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- TOP BAR -->

                        <DockPanel Grid.Row="0"
                                   Margin="0,0,0,20">

                            <TextBlock Text="Installed Applications"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>

                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Right">

                                <TextBox x:Name="SearchBox"
                                         Width="260"
                                         Height="42"
                                         Margin="0,0,14,0"
                                         Background="#0F172A"
                                         Foreground="White"
                                         BorderBrush="#1E293B"
                                         Padding="12,0"
                                         VerticalContentAlignment="Center"
                                         TextChanged="SearchBox_TextChanged"/>

                                <Button Content="Uninstall Selected"
                                        Width="190"
                                        Height="42"
                                        Background="#DC2626"
                                        Foreground="White"
                                        BorderBrush="Transparent"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Click="UninstallSelected_Click"/>

                            </StackPanel>

                        </DockPanel>

                        <!-- APPS GRID -->

                        <Border Grid.Row="1"
                                Background="#111827"
                                CornerRadius="18"
                                BorderBrush="#1E293B"
                                BorderThickness="1">

                            <DataGrid x:Name="AppsGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      Background="#111827"
                                      Foreground="White"
                                      BorderThickness="0"/>

                        </Border>

                    </Grid>

                </Border>

            </Grid>

            <!-- CLEANUP PAGE -->

            <Grid x:Name="CleanupPage"
                  Visibility="Collapsed">

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Cleanup Engine"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <Button Content="Scan Leftovers"
                                Width="220"
                                Height="46"
                                Margin="0,24,0,24"
                                Background="#16A34A"
                                Foreground="White"
                                BorderBrush="Transparent"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Click="ScanLeftovers_Click"/>

                        <TextBlock x:Name="LeftoverResultsText"
                                   Foreground="White"
                                   FontSize="15"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- STORAGE PAGE -->

            <Grid x:Name="StoragePage"
                  Visibility="Collapsed">

                <UniformGrid Columns="2">

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="Downloads Folder"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock x:Name="DownloadsSizeText"
                                       FontSize="44"
                                       FontWeight="Bold"
                                       Foreground="#2563EB"
                                       Margin="0,20,0,0"/>

                        </StackPanel>

                    </Border>

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="Largest Installed Apps"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,18"/>

                            <ScrollViewer Height="500">

                                <TextBlock x:Name="LargestAppsText"
                                           Foreground="#CBD5E1"
                                           FontSize="15"
                                           TextWrapping="Wrap"/>

                            </ScrollViewer>

                        </StackPanel>

                    </Border>

                </UniformGrid>

            </Grid>

            <!-- ACTIVITY PAGE -->

            <Grid x:Name="ActivityPage"
                  Visibility="Collapsed">

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Activity Feed"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,20"/>

                        <ScrollViewer Height="620">

                            <TextBlock x:Name="ActivityText"
                                       Foreground="#E2E8F0"
                                       FontSize="15"
                                       TextWrapping="Wrap"
                                       LineHeight="28"/>

                        </ScrollViewer>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Window>
