<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Height="850"
        Width="1450"
        WindowStartupLocation="CenterScreen"
        Background="#0B1020">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Background="#070B16"
                BorderBrush="#1B2236"
                BorderThickness="0,0,1,0">

            <StackPanel Margin="18">

                <!-- Logo -->
                <StackPanel Margin="0,20,0,30">

                    <TextBlock Text="Tidy"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Windows 11 Cleanup"
                               Foreground="#7E8AA8"
                               FontSize="13"/>
                </StackPanel>

                <!-- Nav Buttons -->

                <Button Content="Dashboard"
                        Height="48"
                        Margin="0,0,0,10"/>

                <Button Content="Installed Apps"
                        Height="48"
                        Margin="0,0,0,10"/>

                <Button Content="Bloatware"
                        Height="48"
                        Margin="0,0,0,10"/>

                <Button Content="Leftovers"
                        Height="48"
                        Margin="0,0,0,10"/>

                <Button Content="Activity"
                        Height="48"/>

            </StackPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1"
              Margin="28">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <DockPanel>

                <StackPanel>

                    <TextBlock Text="Dashboard"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="An overview of what's installed and what could go."
                               Foreground="#95A1BE"
                               FontSize="15"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Button Content="Refresh"
                        Width="130"
                        Height="42"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"/>

            </DockPanel>

            <!-- TOP CARDS -->
            <Grid Grid.Row="1"
                  Margin="0,30,0,30">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cleanup Score -->
                <Border Background="#11182D"
                        CornerRadius="18"
                        Padding="24"
                        Margin="0,0,20,0">

                    <StackPanel>

                        <TextBlock Text="CLEANUP SCORE"
                                   Foreground="#8FA1CC"
                                   FontSize="13"/>

                        <TextBlock Text="20"
                                   FontSize="56"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,12,0,0"/>

                        <TextBlock Text="Needs cleanup"
                                   FontSize="24"
                                   Foreground="#FF4D6D"
                                   Margin="0,10,0,0"/>

                        <TextBlock Text="Based on unused apps and storage usage."
                                   Foreground="#95A1BE"
                                   FontSize="14"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                </Border>

                <!-- Installed -->
                <Border Grid.Column="1"
                        Background="#11182D"
                        CornerRadius="18"
                        Padding="24"
                        Margin="0,0,20,0">

                    <StackPanel>

                        <TextBlock Text="INSTALLED"
                                   Foreground="#8FA1CC"
                                   FontSize="13"/>

                        <TextBlock x:Name="InstalledCountText"
                                   Text="0"
                                   FontSize="44"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,18,0,0"/>

                        <TextBlock Text="Apps detected"
                                   Foreground="#95A1BE"
                                   FontSize="14"/>

                    </StackPanel>

                </Border>

                <!-- Disk Used -->
                <Border Grid.Column="2"
                        Background="#11182D"
                        CornerRadius="18"
                        Padding="24">

                    <StackPanel>

                        <TextBlock Text="DISK USED"
                                   Foreground="#8FA1CC"
                                   FontSize="13"/>

                        <TextBlock x:Name="DiskUsageText"
                                   Text="0 GB"
                                   FontSize="44"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,18,0,0"/>

                        <TextBlock Text="By installed apps"
                                   Foreground="#95A1BE"
                                   FontSize="14"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- APP LIST -->
            <Border Grid.Row="2"
                    Background="#11182D"
                    CornerRadius="18"
                    Padding="18">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,18">

                        <TextBlock Text="Installed Applications"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBox x:Name="SearchBox"
                                 Width="260"
                                 Height="38"
                                 DockPanel.Dock="Right"
                                 TextChanged="SearchBox_TextChanged"/>

                    </DockPanel>

                    <ListView x:Name="AppsList"
                              Grid.Row="1"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="White">

                        <ListView.View>
                            <GridView>

                                <GridViewColumn Header="Application"
                                                Width="320"
                                                DisplayMemberBinding="{Binding Name}"/>

                                <GridViewColumn Header="Publisher"
                                                Width="220"
                                                DisplayMemberBinding="{Binding Publisher}"/>

                                <GridViewColumn Header="Install Date"
                                                Width="150"
                                                DisplayMemberBinding="{Binding InstallDate}"/>

                                <GridViewColumn Header="Size"
                                                Width="120"
                                                DisplayMemberBinding="{Binding Size}"/>

                            </GridView>
                        </ListView.View>

                    </ListView>

                </Grid>

            </Border>

        </Grid>

    </Grid>
</Window>
