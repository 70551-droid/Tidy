<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Height="500"
        Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <StackPanel>

            <TextBlock Text="Tidy"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <Button Content="Test Window"
                    Width="120"
                    Height="40"
                    Click="Test_Click"/>

        </StackPanel>
    </Grid>
</Window>
