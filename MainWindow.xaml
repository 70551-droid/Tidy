<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Height="1040"
        Width="1780"
        MinHeight="850"
        MinWidth="1450"
        WindowStartupLocation="CenterScreen"
        Background="#0B1020">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Background="#070B16"
                BorderBrush="#1D2945"
                BorderThickness="0,0,1,0">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- BRAND -->
                <StackPanel Margin="22,28,22,20">

                    <Border Width="64"
                            Height="64"
                            CornerRadius="18"
                            Background="#1B5CFF">

                        <TextBlock Text="T"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                    </Border>

                    <TextBlock Text="Tidy"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,16,0,0"/>

                    <TextBlock Text="Windows Intelligence Suite"
                               FontSize="13"
                               Foreground="#8FA1CC"
                               Margin="0,5,0,0"/>

                </StackPanel>

                <!-- MENU -->
                <StackPanel Grid.Row="1"
                            Margin="14,0">

                    <StackPanel.Resources>

                        <Style TargetType="Button">

                            <Setter Property="Height" Value="54"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="#121B31"/>
                            <Setter Property="BorderBrush" Value="#233253"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontSize" Value="15"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Padding" Value="18,0,0,0"/>

                            <Style.Triggers>

                                <Trigger Property="IsMouseOver"
                                         Value="True">

                                    <Setter Property="Background"
                                            Value="#1B5CFF"/>

                                    <Setter Property="BorderBrush"
                                            Value="#4A7DFF"/>

                                </Trigger>

                            </Style.Triggers>

                        </Style>

                    </StackPanel.Resources>

                    <Button Content="Dashboard"/>
                    <Button Content="Installed Apps"/>
                    <Button Content="Storage Intelligence"/>
                    <Button Content="Cleanup Engine"/>
                    <Button Content="Startup Apps"/>
                    <Button Content="Recommendations"/>
                    <Button Content="Activity"/>
                    <Button Content="Settings"/>

                </StackPanel>

                <!-- STATUS -->
                <Border Grid.Row="2"
                        Margin="16"
                        Padding="16"
                        CornerRadius="16"
                        Background="#121B31"
                        BorderBrush="#233253"
                        BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="STATUS"
                                   Foreground="#8FA1CC"
                                   FontSize="11"/>

                        <TextBlock Text="Intelligence Engine Active"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   Margin="0,6,0,0"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Border>

        <!-- MAIN -->
        <Grid Grid.Column="1"
              Margin="24">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="420"/>
                <RowDefinition Height="260"/>
                <RowDefinition Height="320"/>
                <RowDefinition Height="260"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <DockPanel Margin="0,0,0,24">

                <StackPanel>

                    <TextBlock Text="Dashboard"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Advanced Windows cleanup and intelligence"
                               Foreground="#8FA1CC"
                               FontSize="14"
                               Margin="0,5,0,0"/>

                </StackPanel>

                <Button Content="Refresh"
                        Width="130"
                        Height="42"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        Click="Refresh_Click"
                        Background="#1B5CFF"
                        Foreground="White"
                        BorderBrush="#4A7DFF"/>

            </DockPanel>

            <!-- LIVE STATS -->
            <Grid Grid.Row="1"
                  Margin="0,0,0,24">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CPU -->
                <Border Background="#121B31"
                        CornerRadius="18"
                        Margin="0,0,12,0"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="CPU"
                                   Foreground="#8FA1CC"/>

                        <TextBlock x:Name="CpuUsageText"
                                   Text="0%"
                                   FontSize="38"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,12,0,0"/>

                    </StackPanel>

                </Border>

                <!-- RAM -->
                <Border Grid.Column="1"
                        Background="#121B31"
                        CornerRadius="18"
                        Margin="0,0,12,0"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="RAM"
                                   Foreground="#8FA1CC"/>

                        <TextBlock x:Name="RamUsageText"
                                   Text="0%"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,12,0,0"/>

                        <TextBlock x:Name="RamFigureText"
                                   Text="0 GB / 0 GB"
                                   Foreground="#9FB2D9"
                                   Margin="0,8,0,0"/>

                    </StackPanel>

                </Border>

                <!-- DISK -->
                <Border Grid.Column="2"
                        Background="#121B31"
                        CornerRadius="18"
                        Margin="0,0,12,0"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="DISK"
                                   Foreground="#8FA1CC"/>

                        <TextBlock x:Name="DiskUsageText"
                                   Text="0%"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,12,0,0"/>

                        <TextBlock x:Name="DiskFigureText"
                                   Text="0 GB Free"
                                   Foreground="#9FB2D9"
                                   Margin="0,8,0,0"/>

                    </StackPanel>

                </Border>

                <!-- APPS -->
                <Border Grid.Column="3"
                        Background="#121B31"
                        CornerRadius="18"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="INSTALLED APPS"
                                   Foreground="#8FA1CC"/>

                        <TextBlock x:Name="InstalledCountText"
                                   Text="0"
                                   FontSize="38"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,12,0,0"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- APPS -->
            <Border Grid.Row="2"
                    Background="#121B31"
                    CornerRadius="18"
                    Padding="18"
                    Margin="0,0,0,24">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,16">

                        <TextBlock Text="Installed Applications"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBox x:Name="SearchBox"
                                 Width="260"
                                 Height="38"
                                 DockPanel.Dock="Right"
                                 TextChanged="SearchBox_TextChanged"
                                 Background="#182038"
                                 Foreground="White"
                                 BorderBrush="#2A3B66"/>

                    </DockPanel>

                    <DataGrid x:Name="AppsGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Extended"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              Background="#121B31"
                              Foreground="White"
                              RowBackground="#121B31"
                              AlternatingRowBackground="#182038"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Application"
                                                Width="*"
                                                Binding="{Binding Name}"/>

                            <DataGridTextColumn Header="Category"
                                                Width="140"
                                                Binding="{Binding Category}"/>

                            <DataGridTextColumn Header="Publisher"
                                                Width="220"
                                                Binding="{Binding Publisher}"/>

                            <DataGridTextColumn Header="Size"
                                                Width="120"
                                                Binding="{Binding Size}"/>

                            <DataGridTemplateColumn Header="Action"
                                                    Width="140">

                                <DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <Button Content="Uninstall"
                                                Height="32"
                                                Background="#D83B3B"
                                                Foreground="White"
                                                Click="UninstallButton_Click"/>

                                    </DataTemplate>

                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                    <Button Grid.Row="2"
                            Content="Batch Uninstall Selected"
                            Width="240"
                            Height="40"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Left"
                            Background="#B91C1C"
                            Foreground="White"
                            Click="BatchUninstall_Click"/>

                </Grid>

            </Border>

            <!-- INTELLIGENCE -->
            <Grid Grid.Row="3"
                  Margin="0,0,0,24">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- DOWNLOADS -->
                <Border Background="#121B31"
                        CornerRadius="18"
                        Margin="0,0,12,0"
                        Padding="18">

                    <StackPanel>

                        <TextBlock Text="Downloads"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock x:Name="DownloadsSizeText"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="#1B5CFF"
                                   Margin="0,18,0,0"/>

                    </StackPanel>

                </Border>

                <!-- LARGEST APPS -->
                <Border Grid.Column="1"
                        Background="#121B31"
                        CornerRadius="18"
                        Margin="0,0,12,0"
                        Padding="18">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Largest Apps"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,18"/>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">

                            <TextBlock x:Name="LargestAppsText"
                                       Foreground="#D6DCEF"
                                       TextWrapping="Wrap"/>

                        </ScrollViewer>

                    </Grid>

                </Border>

                <!-- RECOMMENDATIONS -->
                <Border Grid.Column="2"
                        Background="#121B31"
                        CornerRadius="18"
                        Padding="18">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Smart Recommendations"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,18"/>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">

                            <TextBlock x:Name="RecommendationsText"
                                       Foreground="#D6DCEF"
                                       TextWrapping="Wrap"/>

                        </ScrollViewer>

                    </Grid>

                </Border>

            </Grid>

            <!-- CLEANUP -->
            <Grid Grid.Row="4"
                  Margin="0,0,0,24">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFTOVERS -->
                <Border Background="#121B31"
                        CornerRadius="18"
                        Margin="0,0,12,0"
                        Padding="18">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Leftover Cleanup"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <Button Grid.Row="1"
                                Content="Scan Leftovers"
                                Height="42"
                                Margin="0,18,0,18"
                                Background="#16A34A"
                                Foreground="White"
                                Click="ScanLeftovers_Click"/>

                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto">

                            <TextBlock x:Name="LeftoverResultsText"
                                       Foreground="#D6DCEF"
                                       TextWrapping="Wrap"/>

                        </ScrollViewer>

                    </Grid>

                </Border>

                <!-- STORE -->
                <Border Grid.Column="1"
                        Background="#121B31"
                        CornerRadius="18"
                        Padding="18">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Microsoft Store Apps"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,18"/>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">

                            <TextBlock x:Name="StoreAppsText"
                                       Foreground="#D6DCEF"
                                       TextWrapping="Wrap"/>

                        </ScrollViewer>

                    </Grid>

                </Border>

            </Grid>

            <!-- ACTIVITY -->
            <Border Grid.Row="5"
                    Background="#121B31"
                    CornerRadius="18"
                    Padding="18">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Activity"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,18"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">

                        <TextBlock x:Name="ActivityText"
                                   Foreground="#D6DCEF"
                                   FontSize="15"
                                   TextWrapping="Wrap"/>

                    </ScrollViewer>

                </Grid>

            </Border>

        </Grid>

    </Grid>
</Window>
