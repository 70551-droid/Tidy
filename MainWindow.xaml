<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Height="920"
        Width="1550"
        WindowStartupLocation="CenterScreen"
        Background="#0B1020">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Background="#070B16"
                BorderBrush="#1B2236"
                BorderThickness="0,0,1,0">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LOGO -->
                <StackPanel Margin="24,28,24,24">

                    <Border Width="62"
                            Height="62"
                            CornerRadius="18"
                            Background="#1B5CFF">

                        <TextBlock Text="T"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                    </Border>

                    <TextBlock Text="Tidy"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,16,0,0"/>

                    <TextBlock Text="Windows 11 Cleanup"
                               Foreground="#7E8AA8"
                               FontSize="13"
                               Margin="0,4,0,0"/>

                </StackPanel>

                <!-- NAV -->
                <StackPanel Grid.Row="1"
                            Margin="16,10,16,10">

                    <StackPanel.Resources>

                        <Style TargetType="Button">

                            <Setter Property="Height" Value="52"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="#11182D"/>
                            <Setter Property="BorderBrush" Value="#1D2945"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontSize" Value="15"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Padding" Value="18,0,0,0"/>
                            <Setter Property="Cursor" Value="Hand"/>

                            <Style.Triggers>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1B5CFF"/>
                                    <Setter Property="BorderBrush" Value="#4A7DFF"/>
                                </Trigger>

                            </Style.Triggers>

                        </Style>

                    </StackPanel.Resources>

                    <Button x:Name="DashboardButton"
                            Content="Dashboard"/>

                    <Button x:Name="AppsButton"
                            Content="Installed Apps"/>

                    <Button x:Name="StartupButton"
                            Content="Startup Apps"/>

                    <Button x:Name="ActivityButton"
                            Content="Activity"/>

                    <Button x:Name="SettingsButton"
                            Content="Settings"/>

                </StackPanel>

                <!-- FOOTER -->
                <Border Grid.Row="2"
                        Margin="16"
                        Padding="16"
                        CornerRadius="16"
                        Background="#11182D"
                        BorderBrush="#1D2945"
                        BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="System Status"
                                   Foreground="#8FA1CC"
                                   FontSize="12"/>

                        <TextBlock Text="Tidy is running normally"
                                   Foreground="White"
                                   FontSize="14"
                                   Margin="0,6,0,0"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Border>

        <!-- MAIN -->
        <Grid Grid.Column="1"
              Margin="28">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <DockPanel>

                <StackPanel>

                    <TextBlock Text="Dashboard"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Installed apps and cleanup insights."
                               Foreground="#95A1BE"
                               FontSize="15"
                               Margin="0,6,0,0"/>

                </StackPanel>

                <Button Content="Refresh"
                        Width="130"
                        Height="42"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        Click="Refresh_Click"
                        Background="#1B5CFF"
                        Foreground="White"
                        BorderBrush="#4A7DFF"/>

            </DockPanel>

            <!-- CARDS -->
            <Grid Grid.Row="1"
                  Margin="0,30,0,30">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="#11182D"
                        CornerRadius="18"
                        Padding="24"
                        Margin="0,0,20,0">

                    <StackPanel>

                        <TextBlock Text="CLEANUP SCORE"
                                   Foreground="#8FA1CC"
                                   FontSize="13"/>

                        <TextBlock x:Name="CleanupScoreText"
                                   Text="0"
                                   FontSize="56"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,12,0,0"/>

                        <TextBlock x:Name="CleanupStatusText"
                                   Text="Analyzing"
                                   FontSize="24"
                                   Foreground="#FF4D6D"
                                   Margin="0,10,0,0"/>

                    </StackPanel>

                </Border>

                <Border Grid.Column="1"
                        Background="#11182D"
                        CornerRadius="18"
                        Padding="24"
                        Margin="0,0,20,0">

                    <StackPanel>

                        <TextBlock Text="INSTALLED"
                                   Foreground="#8FA1CC"
                                   FontSize="13"/>

                        <TextBlock x:Name="InstalledCountText"
                                   Text="0"
                                   FontSize="44"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,18,0,0"/>

                    </StackPanel>

                </Border>

                <Border Grid.Column="2"
                        Background="#11182D"
                        CornerRadius="18"
                        Padding="24">

                    <StackPanel>

                        <TextBlock Text="DISK USED"
                                   Foreground="#8FA1CC"
                                   FontSize="13"/>

                        <TextBlock x:Name="DiskUsageText"
                                   Text="0 GB"
                                   FontSize="44"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,18,0,0"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- APPS -->
            <Border Grid.Row="2"
                    Background="#11182D"
                    CornerRadius="18"
                    Padding="18"
                    Margin="0,0,0,24">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,18">

                        <TextBlock Text="Installed Applications"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBox x:Name="SearchBox"
                                 Width="260"
                                 Height="38"
                                 DockPanel.Dock="Right"
                                 TextChanged="SearchBox_TextChanged"
                                 Background="#182038"
                                 Foreground="White"
                                 BorderBrush="#2A3B66"/>

                    </DockPanel>

                    <DataGrid x:Name="AppsGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              Background="#11182D"
                              Foreground="White"
                              RowBackground="#11182D"
                              AlternatingRowBackground="#182038">

                        <DataGrid.Resources>

                            <Style TargetType="DataGridColumnHeader">

                                <Setter Property="Background"
                                        Value="#182038"/>

                                <Setter Property="Foreground"
                                        Value="White"/>

                                <Setter Property="BorderBrush"
                                        Value="#1D2945"/>

                                <Setter Property="FontWeight"
                                        Value="Bold"/>

                                <Setter Property="Height"
                                        Value="42"/>

                            </Style>

                            <Style TargetType="DataGridRow">

                                <Setter Property="Foreground"
                                        Value="White"/>

                                <Setter Property="Background"
                                        Value="#11182D"/>

                                <Setter Property="BorderThickness"
                                        Value="0"/>

                                <Style.Triggers>

                                    <Trigger Property="IsMouseOver"
                                             Value="True">

                                        <Setter Property="Background"
                                                Value="#22304F"/>

                                    </Trigger>

                                    <Trigger Property="IsSelected"
                                             Value="True">

                                        <Setter Property="Background"
                                                Value="#1B5CFF"/>

                                        <Setter Property="Foreground"
                                                Value="White"/>

                                    </Trigger>

                                </Style.Triggers>

                            </Style>

                            <Style TargetType="DataGridCell">

                                <Setter Property="BorderThickness"
                                        Value="0"/>

                                <Setter Property="Foreground"
                                        Value="White"/>

                                <Setter Property="Padding"
                                        Value="10,6"/>

                                <Setter Property="Background"
                                        Value="Transparent"/>

                                <Setter Property="FocusVisualStyle"
                                        Value="{x:Null}"/>

                            </Style>

                        </DataGrid.Resources>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Application"
                                                Width="*"
                                                Binding="{Binding Name}"/>

                            <DataGridTextColumn Header="Publisher"
                                                Width="220"
                                                Binding="{Binding Publisher}"/>

                            <DataGridTextColumn Header="Size"
                                                Width="120"
                                                Binding="{Binding Size}"/>

                            <DataGridTemplateColumn Header="Action"
                                                    Width="140">

                                <DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <Button Content="Uninstall"
                                                Height="32"
                                                Background="#D83B3B"
                                                Foreground="White"
                                                Click="UninstallButton_Click"/>

                                    </DataTemplate>

                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

            <!-- BOTTOM -->
            <Grid Grid.Row="3">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- STARTUP -->
                <Border Background="#11182D"
                        CornerRadius="18"
                        Padding="18"
                        Margin="0,0,12,0">

                    <StackPanel>

                        <TextBlock Text="Startup Apps"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,14"/>

                        <TextBlock x:Name="StartupAppsText"
                                   Foreground="#D6DCEF"
                                   FontSize="15"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                </Border>

                <!-- ACTIVITY -->
                <Border Grid.Column="1"
                        Background="#11182D"
                        CornerRadius="18"
                        Padding="18"
                        Margin="12,0,0,0">

                    <StackPanel>

                        <TextBlock Text="Activity"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,14"/>

                        <TextBlock x:Name="ActivityText"
                                   Text="No recent activity."
                                   Foreground="#D6DCEF"
                                   FontSize="15"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </Grid>
</Window>
