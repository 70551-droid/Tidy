<Window
    x:Class="Tidy.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Tidy">

    <Grid Padding="20">
        <StackPanel Spacing="12">

            <TextBlock Text="Tidy" FontSize="28" FontWeight="Bold"/>

            <TextBox x:Name="SearchBox" PlaceholderText="Search installed apps..."/>

            <ListView x:Name="AppsList" Height="400"/>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Uninstall Selected" Click="Uninstall_Click"/>
                <Button Content="Refresh" Click="Refresh_Click"/>
            </StackPanel>

            <ProgressBar x:Name="Progress" Height="6"/>

            <ScrollViewer Height="120">
                <TextBlock x:Name="Logs" TextWrapping="Wrap" FontFamily="Consolas"/>
            </ScrollViewer>

        </StackPanel>
    </Grid>
</Window>