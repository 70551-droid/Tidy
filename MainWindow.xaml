<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Height="900"
        Width="1500"
        WindowStartupLocation="CenterScreen"
        Background="#070B14">

    <Window.Resources>

        <SolidColorBrush x:Key="SidebarBrush" Color="#0B1220"/>
        <SolidColorBrush x:Key="CardBrush" Color="#111827"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="BorderBrushCustom" Color="#1E293B"/>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}">

            <StackPanel>

                <TextBlock Text="Tidy"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="Bold"
                           Margin="20"/>

                <Button x:Name="DashboardButton"
                        Content="Dashboard"
                        Style="{StaticResource NavButtonStyle}"
                        Click="DashboardButton_Click"/>

                <Button x:Name="AppsButton"
                        Content="Installed Apps"
                        Style="{StaticResource NavButtonStyle}"
                        Click="AppsButton_Click"/>

                <Button x:Name="CleanupButton"
                        Content="Cleanup Engine"
                        Style="{StaticResource NavButtonStyle}"
                        Click="CleanupButton_Click"/>

                <Button x:Name="StorageButton"
                        Content="Storage"
                        Style="{StaticResource NavButtonStyle}"
                        Click="StorageButton_Click"/>

                <Button x:Name="ActivityButton"
                        Content="Activity"
                        Style="{StaticResource NavButtonStyle}"
                        Click="ActivityButton_Click"/>

                <Button Content="Startup Apps"
                        Style="{StaticResource NavButtonStyle}"
                        Click="StartupButton_Click"/>

                <Button Content="Duplicate Finder"
                        Style="{StaticResource NavButtonStyle}"
                        Click="DuplicateButton_Click"/>

                <Button Content="Themes"
                        Style="{StaticResource NavButtonStyle}"
                        Click="ThemesButton_Click"/>

                <Button Content="AI Tools"
                        Style="{StaticResource NavButtonStyle}"
                        Click="AiButton_Click"/>

            </StackPanel>

        </Border>

        <!-- MAIN AREA -->

        <Grid Grid.Column="1">

            <!-- DASHBOARD -->

            <ScrollViewer x:Name="DashboardPage"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel Margin="25">

                    <TextBlock Text="Dashboard"
                               Foreground="White"
                               FontSize="40"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <WrapPanel>

                        <Border Background="{StaticResource CardBrush}"
                                CornerRadius="15"
                                Padding="20"
                                Margin="10"
                                Width="250">

                            <StackPanel>
                                <TextBlock Text="CPU Usage"
                                           Foreground="White"
                                           FontSize="20"/>

                                <TextBlock x:Name="CpuUsageText"
                                           Text="0%"
                                           Foreground="#4ADE80"
                                           FontSize="34"
                                           FontWeight="Bold"/>
                            </StackPanel>

                        </Border>

                        <Border Background="{StaticResource CardBrush}"
                                CornerRadius="15"
                                Padding="20"
                                Margin="10"
                                Width="250">

                            <StackPanel>
                                <TextBlock Text="RAM Usage"
                                           Foreground="White"
                                           FontSize="20"/>

                                <TextBlock x:Name="RamFigureText"
                                           Text="0 GB"
                                           Foreground="#60A5FA"
                                           FontSize="34"
                                           FontWeight="Bold"/>
                            </StackPanel>

                        </Border>

                        <Border Background="{StaticResource CardBrush}"
                                CornerRadius="15"
                                Padding="20"
                                Margin="10"
                                Width="250">

                            <StackPanel>
                                <TextBlock Text="Disk Usage"
                                           Foreground="White"
                                           FontSize="20"/>

                                <TextBlock x:Name="DiskUsageText"
                                           Text="0 GB"
                                           Foreground="#FACC15"
                                           FontSize="34"
                                           FontWeight="Bold"/>
                            </StackPanel>

                        </Border>

                    </WrapPanel>

                </StackPanel>

            </ScrollViewer>

            <!-- APPS PAGE -->

            <ScrollViewer x:Name="AppsPage"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel Margin="25">

                    <TextBlock Text="Installed Applications"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <TextBox x:Name="SearchBox"
                             Height="40"
                             FontSize="16"
                             Margin="0,0,0,20"
                             TextChanged="SearchBox_TextChanged"/>

                    <TextBlock x:Name="InstalledCountText"
                               Text="0 Apps Installed"
                               Foreground="#9CA3AF"
                               FontSize="16"
                               Margin="0,0,0,15"/>

                    <DataGrid x:Name="AppsGrid"
                              Height="600"
                              AutoGenerateColumns="True"
                              Background="#111827"
                              Foreground="White"/>

                </StackPanel>

            </ScrollViewer>

            <!-- CLEANUP PAGE -->

            <ScrollViewer x:Name="CleanupPage"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel Margin="25">

                    <TextBlock Text="Cleanup Engine"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <WrapPanel Margin="0,10,0,20">

                        <Button Content="Clean Temp"
                                Width="180"
                                Height="50"
                                Margin="10"
                                Background="#16A34A"
                                Foreground="White"
                                Click="CleanTemp_Click"/>

                        <Button Content="Clean Recycle Bin"
                                Width="180"
                                Height="50"
                                Margin="10"
                                Background="#2563EB"
                                Foreground="White"
                                Click="CleanRecycle_Click"/>

                        <Button Content="Boost Mode"
                                Width="180"
                                Height="50"
                                Margin="10"
                                Background="#DC2626"
                                Foreground="White"
                                Click="BoostMode_Click"/>

                    </WrapPanel>

                    <TextBlock x:Name="CleanupResultText"
                               Text="Awaiting cleanup..."
                               Foreground="White"
                               FontSize="18"/>

                </StackPanel>

            </ScrollViewer>

            <!-- STORAGE PAGE -->

            <ScrollViewer x:Name="StoragePage"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel Margin="25">

                    <TextBlock Text="Storage Analyzer"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <Border Background="{StaticResource CardBrush}"
                            Padding="20"
                            CornerRadius="15">

                        <StackPanel>

                            <TextBlock Text="Downloads Folder Size"
                                       Foreground="White"
                                       FontSize="20"/>

                            <TextBlock Text="Scanning..."
                                       x:Name="DownloadsSizeText"
                                       Foreground="#60A5FA"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Margin="0,10,0,0"/>

                        </StackPanel>

                    </Border>

                </StackPanel>

            </ScrollViewer>

            <!-- ACTIVITY PAGE -->

            <ScrollViewer x:Name="ActivityPage"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel Margin="25">

                    <TextBlock Text="Activity Center"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <ListBox x:Name="StartupGrid"
                             Height="500"
                             Background="#111827"
                             Foreground="White"/>

                </StackPanel>

            </ScrollViewer>

        </Grid>

    </Grid>

</Window>
