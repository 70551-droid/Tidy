<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tidy"
        Height="920"
        Width="1650"
        MinHeight="850"
        MinWidth="1450"
        Background="#070B14"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- COLORS -->

        <SolidColorBrush x:Key="SidebarBrush" Color="#0B1220"/>
        <SolidColorBrush x:Key="CardBrush" Color="#111827"/>
        <SolidColorBrush x:Key="BorderBrushCustom" Color="#1E293B"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#172554"/>

        <!-- CARD STYLE -->

        <Style x:Key="CardStyle"
               TargetType="Border">

            <Setter Property="Background"
                    Value="{StaticResource CardBrush}"/>

            <Setter Property="CornerRadius"
                    Value="24"/>

            <Setter Property="Padding"
                    Value="20"/>

            <Setter Property="Margin"
                    Value="0,0,20,20"/>

            <Setter Property="BorderBrush"
                    Value="{StaticResource BorderBrushCustom}"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

        </Style>

        <!-- SIDEBAR BUTTON -->

        <Style x:Key="SidebarButtonStyle"
               TargetType="Button">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="FontSize"
                    Value="16"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Height"
                    Value="56"/>

            <Setter Property="Margin"
                    Value="0,0,0,12"/>

            <Setter Property="Background"
                    Value="Transparent"/>

            <Setter Property="BorderBrush"
                    Value="Transparent"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>

            <Setter Property="Padding"
                    Value="20,0"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">

                            <ContentPresenter VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#172554"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <!-- DATA GRID -->

        <Style TargetType="DataGrid">

            <Setter Property="Background"
                    Value="#111827"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="GridLinesVisibility"
                    Value="None"/>

        </Style>

        <Style TargetType="DataGridColumnHeader">

            <Setter Property="Background"
                    Value="#0F172A"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="FontWeight"
                    Value="Bold"/>

            <Setter Property="Height"
                    Value="42"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

        </Style>

        <Style TargetType="DataGridRow">

            <Setter Property="Background"
                    Value="#111827"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Height"
                    Value="40"/>

            <Style.Triggers>

                <Trigger Property="IsMouseOver"
                         Value="True">

                    <Setter Property="Background"
                            Value="#1D4ED8"/>

                </Trigger>

                <Trigger Property="IsSelected"
                         Value="True">

                    <Setter Property="Background"
                            Value="#2563EB"/>

                </Trigger>

            </Style.Triggers>

        </Style>

        <Style TargetType="DataGridCell">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="Padding"
                    Value="10,4"/>

        </Style>

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel Margin="18">

                    <TextBlock Text="Tidy"
                               FontSize="40"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="10,20,0,40"/>

                    <Button x:Name="DashboardButton"
                            Content="Dashboard"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="DashboardButton_Click"/>

                    <Button x:Name="AppsButton"
                            Content="Installed Apps"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="AppsButton_Click"/>

                    <Button x:Name="StartupButton"
                            Content="Startup Apps"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="StartupButton_Click"/>

                    <Button x:Name="CleanupButton"
                            Content="Cleanup"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="CleanupButton_Click"/>

                    <Button x:Name="StorageButton"
                            Content="Storage Analyzer"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="StorageButton_Click"/>

                    <Button x:Name="DuplicateButton"
                            Content="Duplicate Finder"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="DuplicateButton_Click"/>

                    <Button x:Name="ThemesButton"
                            Content="Themes"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="ThemesButton_Click"/>

                    <Button x:Name="AiButton"
                            Content="AI Insights"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="AiButton_Click"/>

                    <Button x:Name="ActivityButton"
                            Content="Activity"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="ActivityButton_Click"/>

                </StackPanel>

            </ScrollViewer>

        </Border>

        <!-- MAIN AREA -->

        <Grid Grid.Column="1"
              Margin="24">

            <!-- DASHBOARD -->

            <ScrollViewer x:Name="DashboardPage">

                <StackPanel>

                    <TextBlock Text="System Dashboard"
                               FontSize="44"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,24"/>

                    <UniformGrid Columns="4">

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="CPU"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="CpuUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,10,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="RAM"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="RamUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,10,0,0"/>

                                <TextBlock x:Name="RamFigureText"
                                           Foreground="#CBD5E1"
                                           Margin="0,8,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="DISK"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="DiskUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,10,0,0"/>

                                <TextBlock x:Name="DiskFigureText"
                                           Foreground="#CBD5E1"
                                           Margin="0,8,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="GPU"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="GpuUsageText"
                                           Text="0%"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,10,0,0"/>

                            </StackPanel>

                        </Border>

                    </UniformGrid>

                    <UniformGrid Columns="3">

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="System Uptime"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="UptimeText"
                                           Text="0 Hours"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,12,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="Battery Health"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="BatteryText"
                                           Text="Good"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="#22C55E"
                                           Margin="0,12,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="Installed Apps"
                                           Foreground="#94A3B8"/>

                                <TextBlock x:Name="InstalledCountText"
                                           Text="0"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,12,0,0"/>

                            </StackPanel>

                        </Border>

                    </UniformGrid>

                </StackPanel>

            </ScrollViewer>

            <!-- INSTALLED APPS -->

            <Grid x:Name="AppsPage"
                  Visibility="Collapsed">

                <Border Style="{StaticResource CardStyle}">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0"
                                   Margin="0,0,0,20">

                            <TextBlock Text="Installed Applications"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Right">

                                <TextBox x:Name="SearchBox"
                                         Width="260"
                                         Height="42"
                                         Margin="0,0,14,0"
                                         Background="#0F172A"
                                         Foreground="White"
                                         BorderBrush="#1E293B"
                                         Padding="12,0"
                                         VerticalContentAlignment="Center"
                                         TextChanged="SearchBox_TextChanged"/>

                                <Button Content="Uninstall Selected"
                                        Width="190"
                                        Height="42"
                                        Background="#DC2626"
                                        Foreground="White"
                                        BorderBrush="Transparent"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Click="UninstallSelected_Click"/>

                            </StackPanel>

                        </DockPanel>

                        <DataGrid x:Name="AppsGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                    </Grid>

                </Border>

            </Grid>

            <!-- STARTUP PAGE -->

            <Grid x:Name="StartupPage"
                  Visibility="Collapsed">

                <Border Style="{StaticResource CardStyle}">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Startup Applications"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,20"/>

                        <DataGrid x:Name="StartupGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"/>

                    </Grid>

                </Border>

            </Grid>

            <!-- CLEANUP PAGE -->

            <Grid x:Name="CleanupPage"
                  Visibility="Collapsed">

                <ScrollViewer>

                    <StackPanel>

                        <Border Style="{StaticResource CardStyle}">

                            <StackPanel>

                                <TextBlock Text="Cleanup Engine"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Foreground="White"/>

                                <WrapPanel Margin="0,24,0,0">

                                    <Button Content="Clean Temp"
                                            Width="180"
                                            Height="46"
                                            Margin="0,0,12,12"
                                            Background="#16A34A"
                                            Foreground="White"
                                            BorderBrush="Transparent"
                                            Click="CleanTemp_Click"/>

                                    <Button Content="Clean Recycle Bin"
                                            Width="180"
                                            Height="46"
                                            Margin="0,0,12,12"
                                            Background="#2563EB"
                                            Foreground="White"
                                            BorderBrush="Transparent"
                                            Click="CleanRecycleBin_Click"/>

                                    <Button Content="Boost Mode"
                                            Width="180"
                                            Height="46"
                                            Margin="0,0,12,12"
                                            Background="#DC2626"
                                            Foreground="White"
                                            BorderBrush="Transparent"
                                            Click="BoostMode_Click"/>

                                </WrapPanel>

                                <ProgressBar x:Name="CleanupProgress"
                                             Height="22"
                                             Margin="0,20,0,0"/>

                                <TextBlock x:Name="CleanupStatusText"
                                           Foreground="#CBD5E1"
                                           Margin="0,20,0,0"
                                           FontSize="16"/>

                            </StackPanel>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

            </Grid>

            <!-- STORAGE -->

            <Grid x:Name="StoragePage"
                  Visibility="Collapsed">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Storage Analyzer"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,20"/>

                <Grid Grid.Row="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardStyle}"
                            Grid.Column="0">

                        <StackPanel>

                            <TextBlock Text="Folder Usage"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,18"/>

                            <TextBlock x:Name="DownloadsSizeText"
                                       Foreground="#CBD5E1"
                                       FontSize="16"
                                       Margin="0,0,0,10"/>

                            <TextBlock x:Name="DesktopSizeText"
                                       Foreground="#CBD5E1"
                                       FontSize="16"
                                       Margin="0,0,0,10"/>

                            <TextBlock x:Name="DocumentsSizeText"
                                       Foreground="#CBD5E1"
                                       FontSize="16"/>

                        </StackPanel>

                    </Border>

                    <Border Style="{StaticResource CardStyle}"
                            Grid.Column="1">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Margin="0,0,0,20">

                                <TextBlock Text="Large Files Scanner"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="White"/>

                                <Button Content="Scan Files"
                                        Width="160"
                                        Height="42"
                                        Background="#2563EB"
                                        Foreground="White"
                                        BorderBrush="Transparent"
                                        DockPanel.Dock="Right"
                                        Click="ScanLargeFiles_Click"/>

                            </DockPanel>

                            <DataGrid x:Name="LargeFilesGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"/>

                        </Grid>

                    </Border>

                </Grid>

            </Grid>

            <!-- DUPLICATES -->

            <Grid x:Name="DuplicatePage"
                  Visibility="Collapsed">

                <Border Style="{StaticResource CardStyle}">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,0,0,20">

                            <TextBlock Text="Duplicate File Finder"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <Button Content="Scan Duplicates"
                                    Width="180"
                                    Height="42"
                                    Background="#9333EA"
                                    Foreground="White"
                                    BorderBrush="Transparent"
                                    DockPanel.Dock="Right"
                                    Click="ScanDuplicates_Click"/>

                        </DockPanel>

                        <DataGrid x:Name="DuplicateGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"/>

                    </Grid>

                </Border>

            </Grid>

            <!-- THEMES -->

            <Grid x:Name="ThemesPage"
                  Visibility="Collapsed">

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Themes"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <WrapPanel Margin="0,30,0,0">

                            <Button Content="Midnight"
                                    Width="180"
                                    Height="50"
                                    Margin="0,0,14,14"
                                    Click="MidnightTheme_Click"/>

                            <Button Content="AMOLED"
                                    Width="180"
                                    Height="50"
                                    Margin="0,0,14,14"
                                    Click="AmoledTheme_Click"/>

                            <Button Content="Neon"
                                    Width="180"
                                    Height="50"
                                    Margin="0,0,14,14"
                                    Click="NeonTheme_Click"/>

                            <Button Content="Frost"
                                    Width="180"
                                    Height="50"
                                    Margin="0,0,14,14"
                                    Click="FrostTheme_Click"/>

                        </WrapPanel>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- AI INSIGHTS -->

            <Grid x:Name="AiPage"
                  Visibility="Collapsed">

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="AI Recommendations"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,24"/>

                        <ScrollViewer>

                            <TextBlock x:Name="AiInsightsText"
                                       Foreground="#E2E8F0"
                                       FontSize="18"
                                       TextWrapping="Wrap"
                                       LineHeight="32"/>

                        </ScrollViewer>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- ACTIVITY -->

            <Grid x:Name="ActivityPage"
                  Visibility="Collapsed">

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Activity Feed"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,20"/>

                        <ScrollViewer Height="720">

                            <TextBlock x:Name="ActivityText"
                                       Foreground="#E2E8F0"
                                       FontSize="15"
                                       TextWrapping="Wrap"
                                       LineHeight="28"/>

                        </ScrollViewer>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Window>
