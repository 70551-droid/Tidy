<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Height="1040"
        Width="1780"
        MinHeight="850"
        MinWidth="1450"
        WindowStartupLocation="CenterScreen"
        Background="#0B1020">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid Background="#0B1020">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Background="#070B16"
                    BorderBrush="#1D2945"
                    BorderThickness="0,0,1,0">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- BRAND -->
                    <StackPanel Margin="22,28,22,20">

                        <Border Width="64"
                                Height="64"
                                CornerRadius="18"
                                Background="#1B5CFF">

                            <TextBlock Text="T"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                        </Border>

                        <TextBlock Text="Tidy"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,16,0,0"/>

                        <TextBlock Text="Windows Intelligence Suite"
                                   FontSize="13"
                                   Foreground="#8FA1CC"
                                   Margin="0,5,0,0"/>

                    </StackPanel>

                    <!-- MENU -->
                    <StackPanel Grid.Row="1"
                                Margin="14,0">

                        <Button Content="Dashboard"
                                Height="54"
                                Margin="0,0,0,10"/>

                        <Button Content="Installed Apps"
                                Height="54"
                                Margin="0,0,0,10"/>

                        <Button Content="Storage Intelligence"
                                Height="54"
                                Margin="0,0,0,10"/>

                        <Button Content="Cleanup Engine"
                                Height="54"
                                Margin="0,0,0,10"/>

                        <Button Content="Startup Apps"
                                Height="54"
                                Margin="0,0,0,10"/>

                        <Button Content="Recommendations"
                                Height="54"
                                Margin="0,0,0,10"/>

                        <Button Content="Activity"
                                Height="54"
                                Margin="0,0,0,10"/>

                        <Button Content="Settings"
                                Height="54"/>

                    </StackPanel>

                </Grid>

            </Border>

            <!-- MAIN CONTENT -->
            <StackPanel Grid.Column="1"
                        Margin="24">

                <!-- HEADER -->
                <DockPanel Margin="0,0,0,24">

                    <StackPanel>

                        <TextBlock Text="Dashboard"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Advanced Windows cleanup and intelligence"
                                   Foreground="#8FA1CC"
                                   FontSize="14"
                                   Margin="0,5,0,0"/>

                    </StackPanel>

                    <Button Content="Refresh"
                            Width="130"
                            Height="42"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            Click="Refresh_Click"/>

                </DockPanel>

                <!-- LIVE STATS -->
                <UniformGrid Columns="4"
                             Margin="0,0,0,24">

                    <!-- CPU -->
                    <Border Background="#121B31"
                            CornerRadius="18"
                            Margin="0,0,12,0"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="CPU"
                                       Foreground="#8FA1CC"/>

                            <TextBlock x:Name="CpuUsageText"
                                       Text="0%"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,12,0,0"/>

                        </StackPanel>

                    </Border>

                    <!-- RAM -->
                    <Border Background="#121B31"
                            CornerRadius="18"
                            Margin="0,0,12,0"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="RAM"
                                       Foreground="#8FA1CC"/>

                            <TextBlock x:Name="RamUsageText"
                                       Text="0%"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,12,0,0"/>

                            <TextBlock x:Name="RamFigureText"
                                       Text="0 GB / 0 GB"
                                       Foreground="#9FB2D9"
                                       Margin="0,8,0,0"/>

                        </StackPanel>

                    </Border>

                    <!-- DISK -->
                    <Border Background="#121B31"
                            CornerRadius="18"
                            Margin="0,0,12,0"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="DISK"
                                       Foreground="#8FA1CC"/>

                            <TextBlock x:Name="DiskUsageText"
                                       Text="0%"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,12,0,0"/>

                            <TextBlock x:Name="DiskFigureText"
                                       Text="0 GB Free"
                                       Foreground="#9FB2D9"
                                       Margin="0,8,0,0"/>

                        </StackPanel>

                    </Border>

                    <!-- APPS -->
                    <Border Background="#121B31"
                            CornerRadius="18"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="INSTALLED APPS"
                                       Foreground="#8FA1CC"/>

                            <TextBlock x:Name="InstalledCountText"
                                       Text="0"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,12,0,0"/>

                        </StackPanel>

                    </Border>

                </UniformGrid>

                <!-- APPS GRID -->
                <Border Background="#121B31"
                        CornerRadius="18"
                        Padding="18"
                        Margin="0,0,0,24">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="420"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,0,0,16">

                            <TextBlock Text="Installed Applications"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBox x:Name="SearchBox"
                                     Width="260"
                                     Height="38"
                                     DockPanel.Dock="Right"
                                     TextChanged="SearchBox_TextChanged"/>

                        </DockPanel>

                        <DataGrid x:Name="AppsGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <Button Grid.Row="2"
                                Content="Batch Uninstall Selected"
                                Width="240"
                                Height="40"
                                Margin="0,16,0,0"
                                Click="BatchUninstall_Click"/>

                    </Grid>

                </Border>

                <!-- INTELLIGENCE -->
                <UniformGrid Columns="3"
                             Margin="0,0,0,24">

                    <Border Background="#121B31"
                            CornerRadius="18"
                            Margin="0,0,12,0"
                            Padding="18">

                        <StackPanel>

                            <TextBlock Text="Downloads"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock x:Name="DownloadsSizeText"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="#1B5CFF"
                                       Margin="0,18,0,0"/>

                        </StackPanel>

                    </Border>

                    <Border Background="#121B31"
                            CornerRadius="18"
                            Margin="0,0,12,0"
                            Padding="18">

                        <StackPanel>

                            <TextBlock Text="Largest Apps"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <ScrollViewer Height="180">

                                <TextBlock x:Name="LargestAppsText"
                                           Foreground="#D6DCEF"
                                           TextWrapping="Wrap"/>

                            </ScrollViewer>

                        </StackPanel>

                    </Border>

                    <Border Background="#121B31"
                            CornerRadius="18"
                            Padding="18">

                        <StackPanel>

                            <TextBlock Text="Recommendations"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <ScrollViewer Height="180">

                                <TextBlock x:Name="RecommendationsText"
                                           Foreground="#D6DCEF"
                                           TextWrapping="Wrap"/>

                            </ScrollViewer>

                        </StackPanel>

                    </Border>

                </UniformGrid>

                <!-- CLEANUP -->
                <UniformGrid Columns="2"
                             Margin="0,0,0,24">

                    <Border Background="#121B31"
                            CornerRadius="18"
                            Margin="0,0,12,0"
                            Padding="18">

                        <StackPanel>

                            <TextBlock Text="Leftover Cleanup"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <Button Content="Scan Leftovers"
                                    Height="42"
                                    Margin="0,18,0,18"
                                    Click="ScanLeftovers_Click"/>

                            <ScrollViewer Height="200">

                                <TextBlock x:Name="LeftoverResultsText"
                                           Foreground="#D6DCEF"
                                           TextWrapping="Wrap"/>

                            </ScrollViewer>

                        </StackPanel>

                    </Border>

                    <Border Background="#121B31"
                            CornerRadius="18"
                            Padding="18">

                        <StackPanel>

                            <TextBlock Text="Microsoft Store Apps"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <ScrollViewer Height="260">

                                <TextBlock x:Name="StoreAppsText"
                                           Foreground="#D6DCEF"
                                           TextWrapping="Wrap"/>

                            </ScrollViewer>

                        </StackPanel>

                    </Border>

                </UniformGrid>

                <!-- ACTIVITY -->
                <Border Background="#121B31"
                        CornerRadius="18"
                        Padding="18"
                        Margin="0,0,0,24">

                    <StackPanel>

                        <TextBlock Text="Activity"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,18"/>

                        <ScrollViewer Height="220">

                            <TextBlock x:Name="ActivityText"
                                       Foreground="#D6DCEF"
                                       TextWrapping="Wrap"/>

                        </ScrollViewer>

                    </StackPanel>

                </Border>

            </StackPanel>

        </Grid>

    </ScrollViewer>

</Window>
