<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F0F">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Tidy"
                   FontSize="36"
                   FontWeight="Bold"
                   Foreground="White"/>

        <!-- Search -->
        <TextBox x:Name="SearchBox"
                 Grid.Row="1"
                 Height="40"
                 Margin="0,20,0,20"
                 FontSize="16"
                 TextChanged="SearchBox_TextChanged"/>

        <!-- App List -->
        <Border Grid.Row="2"
                Background="#1A1A1A"
                CornerRadius="12"
                Padding="10">

            <ListView x:Name="AppsList"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="White">

                <ListView.View>
                    <GridView>

                        <GridViewColumn Header="Application"
                                        Width="350"
                                        DisplayMemberBinding="{Binding Name}"/>

                        <GridViewColumn Header="Publisher"
                                        Width="220"
                                        DisplayMemberBinding="{Binding Publisher}"/>

                        <GridViewColumn Header="Install Date"
                                        Width="150"
                                        DisplayMemberBinding="{Binding InstallDate}"/>

                    </GridView>
                </ListView.View>
            </ListView>

        </Border>

        <!-- Bottom -->
        <StackPanel Grid.Row="3"
                    Margin="0,20,0,0">

            <StackPanel Orientation="Horizontal">

                <Button Content="Refresh"
                        Width="120"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="Refresh_Click"/>

                <Button Content="Uninstall Selected"
                        Width="180"
                        Height="40"
                        Click="Uninstall_Click"/>

            </StackPanel>

            <TextBox x:Name="Logs"
                     Margin="0,15,0,0"
                     Height="120"
                     Background="#1A1A1A"
                     Foreground="White"
                     BorderThickness="0"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>

        </StackPanel>

    </Grid>
</Window>
