<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Width="1820"
        Height="1060"
        MinWidth="1500"
        MinHeight="900"
        WindowStartupLocation="CenterScreen"
        Background="#070B14">

    <Window.Resources>

        <!-- COLORS -->

        <SolidColorBrush x:Key="PrimaryBrush"
                         Color="#4F8CFF"/>

        <SolidColorBrush x:Key="CardBrush"
                         Color="#111827"/>

        <SolidColorBrush x:Key="SidebarBrush"
                         Color="#0B1220"/>

        <SolidColorBrush x:Key="BorderBrushCustom"
                         Color="#1F2937"/>

        <SolidColorBrush x:Key="MutedBrush"
                         Color="#94A3B8"/>

        <!-- CARD STYLE -->

        <Style x:Key="CardStyle"
               TargetType="Border">

            <Setter Property="Background"
                    Value="{StaticResource CardBrush}"/>

            <Setter Property="CornerRadius"
                    Value="26"/>

            <Setter Property="Padding"
                    Value="22"/>

            <Setter Property="Margin"
                    Value="0,0,18,18"/>

            <Setter Property="BorderBrush"
                    Value="#1E293B"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

        </Style>

        <!-- SIDEBAR BUTTON -->

        <Style x:Key="SidebarButtonStyle"
               TargetType="Button">

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="FontSize"
                    Value="15"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Height"
                    Value="56"/>

            <Setter Property="Margin"
                    Value="0,0,0,12"/>

            <Setter Property="Padding"
                    Value="18,0"/>

            <Setter Property="Background"
                    Value="Transparent"/>

            <Setter Property="BorderBrush"
                    Value="Transparent"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">

                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="10,0"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#172554"/>

                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#2563EB"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->

            <Border Background="{StaticResource SidebarBrush}"
                    BorderBrush="#111827"
                    BorderThickness="0,0,1,0">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- LOGO -->

                    <StackPanel Margin="30">

                        <Border Width="82"
                                Height="82"
                                CornerRadius="24"
                                Background="{StaticResource PrimaryBrush}">

                            <TextBlock Text="T"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                        </Border>

                        <TextBlock Text="Tidy"
                                   FontSize="38"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,18,0,0"/>

                        <TextBlock Text="Modern Windows Intelligence"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   Margin="0,6,0,0"/>

                    </StackPanel>

                    <!-- NAVIGATION -->

                    <StackPanel Grid.Row="1"
                                Margin="18,10">

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Background="#172554"
                                BorderBrush="#2563EB">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="&#xE80F;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="18"
                                           Margin="0,0,14,0"/>

                                <TextBlock Text="Dashboard"/>

                            </StackPanel>

                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="&#xE719;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="18"
                                           Margin="0,0,14,0"/>

                                <TextBlock Text="Installed Apps"/>

                            </StackPanel>

                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="&#xE7F8;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="18"
                                           Margin="0,0,14,0"/>

                                <TextBlock Text="Storage"/>

                            </StackPanel>

                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="&#xE74D;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="18"
                                           Margin="0,0,14,0"/>

                                <TextBlock Text="Cleanup"/>

                            </StackPanel>

                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="&#xE823;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="18"
                                           Margin="0,0,14,0"/>

                                <TextBlock Text="Startup"/>

                            </StackPanel>

                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="&#xEA18;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="18"
                                           Margin="0,0,14,0"/>

                                <TextBlock Text="Recommendations"/>

                            </StackPanel>

                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="&#xE9D9;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="18"
                                           Margin="0,0,14,0"/>

                                <TextBlock Text="Activity"/>

                            </StackPanel>

                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="&#xE713;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="18"
                                           Margin="0,0,14,0"/>

                                <TextBlock Text="Settings"/>

                            </StackPanel>

                        </Button>

                    </StackPanel>

                    <!-- FOOTER -->

                    <Border Grid.Row="2"
                            Margin="18"
                            Background="#111827"
                            CornerRadius="18"
                            Padding="18"
                            BorderBrush="#1F2937"
                            BorderThickness="1">

                        <StackPanel>

                            <TextBlock Text="SYSTEM STATUS"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"/>

                            <TextBlock Text="Intelligence Engine Active"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       Margin="0,8,0,0"/>

                        </StackPanel>

                    </Border>

                </Grid>

            </Border>

            <!-- MAIN -->

            <StackPanel Grid.Column="1"
                        Margin="30">

                <!-- HEADER -->

                <DockPanel Margin="0,0,0,28">

                    <StackPanel>

                        <TextBlock Text="Dashboard"
                                   FontSize="48"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Advanced cleanup and system intelligence"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="15"
                                   Margin="0,6,0,0"/>

                    </StackPanel>

                    <Button Content="Refresh"
                            Width="150"
                            Height="48"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            Background="{StaticResource PrimaryBrush}"
                            Foreground="White"
                            BorderBrush="Transparent"
                            FontWeight="SemiBold"
                            FontSize="15"
                            Click="Refresh_Click"/>

                </DockPanel>

                <!-- STATS -->

                <UniformGrid Columns="4"
                             Margin="0,0,0,24">

                    <!-- CPU -->

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="CPU"
                                       Foreground="{StaticResource MutedBrush}"/>

                            <TextBlock x:Name="CpuUsageText"
                                       Text="0%"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,14,0,10"/>

                            <ProgressBar Value="45"
                                         Height="8"
                                         Maximum="100"/>

                        </StackPanel>

                    </Border>

                    <!-- RAM -->

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="RAM"
                                       Foreground="{StaticResource MutedBrush}"/>

                            <TextBlock x:Name="RamUsageText"
                                       Text="0%"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,14,0,0"/>

                            <TextBlock x:Name="RamFigureText"
                                       Text="0 GB / 0 GB"
                                       Foreground="#CBD5E1"
                                       Margin="0,8,0,10"/>

                            <ProgressBar Value="65"
                                         Height="8"
                                         Maximum="100"/>

                        </StackPanel>

                    </Border>

                    <!-- DISK -->

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="DISK"
                                       Foreground="{StaticResource MutedBrush}"/>

                            <TextBlock x:Name="DiskUsageText"
                                       Text="0%"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,14,0,0"/>

                            <TextBlock x:Name="DiskFigureText"
                                       Text="0 GB Free"
                                       Foreground="#CBD5E1"
                                       Margin="0,8,0,10"/>

                            <ProgressBar Value="70"
                                         Height="8"
                                         Maximum="100"/>

                        </StackPanel>

                    </Border>

                    <!-- APPS -->

                    <Border Style="{StaticResource CardStyle}">

                        <StackPanel>

                            <TextBlock Text="INSTALLED APPS"
                                       Foreground="{StaticResource MutedBrush}"/>

                            <TextBlock x:Name="InstalledCountText"
                                       Text="0"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,14,0,10"/>

                            <ProgressBar Value="80"
                                         Height="8"
                                         Maximum="100"/>

                        </StackPanel>

                    </Border>

                </UniformGrid>

                <!-- APPS GRID -->

                <Border Style="{StaticResource CardStyle}">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="430"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,0,0,20">

                            <TextBlock Text="Installed Applications"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBox x:Name="SearchBox"
                                     Width="300"
                                     Height="42"
                                     DockPanel.Dock="Right"
                                     Background="#0F172A"
                                     Foreground="White"
                                     BorderBrush="#1E293B"
                                     Padding="12,0"
                                     FontSize="14"
                                     TextChanged="SearchBox_TextChanged"/>

                        </DockPanel>

                        <DataGrid x:Name="AppsGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  Background="#111827"
                                  Foreground="White"
                                  BorderThickness="0"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  RowBackground="#111827"
                                  AlternatingRowBackground="#0F172A"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <Button Grid.Row="2"
                                Content="Batch Uninstall Selected"
                                Width="260"
                                Height="44"
                                Margin="0,20,0,0"
                                HorizontalAlignment="Left"
                                Background="#DC2626"
                                Foreground="White"
                                BorderBrush="Transparent"
                                FontWeight="SemiBold"
                                Click="BatchUninstall_Click"/>

                    </Grid>

                </Border>

            </StackPanel>

        </Grid>

    </ScrollViewer>

</Window>
