<Window x:Class="Tidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tidy"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#111111">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Tidy"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="White"/>

            <Button Content="Refresh"
                    Width="100"
                    Height="35"
                    Margin="20,0,0,0"
                    Click="Refresh_Click"/>
        </StackPanel>

        <!-- Apps List -->
        <Border Grid.Row="1"
                Margin="0,20,0,20"
                CornerRadius="10"
                Background="#1E1E1E"
                Padding="10">

            <ListBox x:Name="AppsList"
                     Background="Transparent"
                     Foreground="White"
                     BorderThickness="0"
                     FontSize="15"/>
        </Border>

        <!-- Bottom -->
        <StackPanel Grid.Row="2">

            <Button Content="Uninstall Selected App"
                    Height="40"
                    Click="Uninstall_Click"/>

            <TextBox x:Name="Logs"
                     Margin="0,10,0,0"
                     Height="100"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

    </Grid>
</Window>
